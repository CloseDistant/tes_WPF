<Window x:Class="RuinaoHardwareDebugWpf.Views.EegParameterSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="采集参数"
        Width="520"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter Property="Background" Value="#2F3542" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#202634" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ParamLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ParamValueBox" TargetType="Border">
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#111722" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="10,0" />
        </Style>

        <Style x:Key="ParamValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ParamComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="#111722" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="#111722"
                                    BorderBrush="{StaticResource Line}"
                                    BorderThickness="1"
                                    CornerRadius="3" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}" />
                            <TextBlock Text="▼"
                                       Foreground="{StaticResource SubText}"
                                       FontSize="9"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <ToggleButton Focusable="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Width="{TemplateBinding ActualWidth}"
                                        Background="{StaticResource Panel}"
                                        BorderBrush="{StaticResource Line}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Margin="0,3,0,0">
                                    <ScrollViewer MaxHeight="180">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#272C38" />
                    <Setter Property="Foreground" Value="{StaticResource Gold}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#303645" />
                    <Setter Property="Foreground" Value="{StaticResource Gold}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogScrollBarThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="#4B5568"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="#10151F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="2,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DialogScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource DialogScrollBar}" />
    </Window.Resources>

    <Border Background="{StaticResource Panel2}"
            BorderBrush="{StaticResource Line}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="16,0">
                    <Button Content="×"
                            DockPanel.Dock="Right"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            Foreground="{StaticResource SubText}"
                            BorderThickness="0"
                            FontSize="18"
                            Click="CancelButton_Click" />
                    <TextBlock Text="采集参数"
                               Foreground="{StaticResource Text}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="28,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="52" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="通道数" Style="{StaticResource ParamLabel}" />
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ParamValueBox}">
                    <TextBlock Text="64 通道" Style="{StaticResource ParamValueText}" />
                </Border>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="采样率" Style="{StaticResource ParamLabel}" />
                <ComboBox x:Name="SampleRateComboBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Style="{StaticResource ParamComboBox}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="高通滤波" Style="{StaticResource ParamLabel}" />
                <ComboBox x:Name="HighPassComboBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          Style="{StaticResource ParamComboBox}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="低通滤波" Style="{StaticResource ParamLabel}" />
                <ComboBox x:Name="LowPassComboBox"
                          Grid.Row="3"
                          Grid.Column="1"
                          Style="{StaticResource ParamComboBox}" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="陷波滤波" Style="{StaticResource ParamLabel}" />
                <ComboBox x:Name="NotchComboBox"
                          Grid.Row="4"
                          Grid.Column="1"
                          Style="{StaticResource ParamComboBox}" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="增益" Style="{StaticResource ParamLabel}" />
                <ComboBox x:Name="GainComboBox"
                          Grid.Row="5"
                          Grid.Column="1"
                          Style="{StaticResource ParamComboBox}" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="参考电极" Style="{StaticResource ParamLabel}" />
                <ComboBox x:Name="ReferenceComboBox"
                          Grid.Row="6"
                          Grid.Column="1"
                          Style="{StaticResource ParamComboBox}" />
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,4,4">
                <Button Content="确定"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Style="{StaticResource DialogButton}"
                        Click="OkButton_Click" />
            </Border>
        </Grid>
    </Border>
</Window>
