<Window x:Class="RuinaoHardwareDebugWpf.Views.Dialogs.AccountListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="900"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="ResetButton" TargetType="Button">
            <Setter Property="Width" Value="82" />
            <Setter Property="Height" Value="27" />
            <Setter Property="Background" Value="#313644" />
            <Setter Property="Foreground" Value="#E4E8EF" />
            <Setter Property="BorderBrush" Value="#4A5161" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D0903E" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D0903E" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B8782E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccountScrollBarThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#4B5568" CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#D0903E" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccountScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="#10151F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="2,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource AccountScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource AccountScrollBar}" />
        <Style TargetType="ListBoxItem">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#E4E8EF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Row" Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#232936" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#30323B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#171B24" BorderBrush="#303645" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54" />
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
                <RowDefinition Height="52" />
            </Grid.RowDefinitions>
            <Border Background="#1C202B"
                    BorderBrush="#303645"
                    BorderThickness="0,0,0,1"
                    CornerRadius="6,6,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="18,0">
                    <Button Content="×"
                            DockPanel.Dock="Right"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            Foreground="#AEB7C7"
                            BorderThickness="0"
                            FontSize="18"
                            Cursor="Hand"
                            Click="CloseButton_Click" />
                    <TextBlock Text="账号列表"
                               Foreground="#E4E8EF"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="24,10,24,8">
                <TextBlock Text="Admin 可重置已启用账号的密码；重置后该账号下次登录必须修改密码。"
                           Foreground="#97A3B6"
                           FontSize="12"
                           VerticalAlignment="Top" />
                <TextBlock x:Name="StatusText"
                           Foreground="#5DDA77"
                           FontSize="12"
                           VerticalAlignment="Bottom" />
            </Grid>

            <Border Grid.Row="2" Margin="24,0" BorderBrush="#303645" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="#202531" BorderBrush="#303645" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="104" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ID" Margin="14,0" VerticalAlignment="Center" Foreground="#AEB7C7" />
                            <TextBlock Grid.Column="1" Text="登录名" Margin="14,0" VerticalAlignment="Center" Foreground="#AEB7C7" />
                            <TextBlock Grid.Column="2" Text="姓名" Margin="14,0" VerticalAlignment="Center" Foreground="#AEB7C7" />
                            <TextBlock Grid.Column="3" Text="角色" Margin="14,0" VerticalAlignment="Center" Foreground="#AEB7C7" />
                            <TextBlock Grid.Column="4" Text="状态" Margin="14,0" VerticalAlignment="Center" Foreground="#AEB7C7" />
                            <TextBlock Grid.Column="5" Text="创建时间" Margin="14,0" VerticalAlignment="Center" Foreground="#AEB7C7" />
                            <TextBlock Grid.Column="6" Text="重置密码" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#AEB7C7" />
                        </Grid>
                    </Border>
                    <ListBox x:Name="AccountListBox"
                             Grid.Row="1"
                             Background="#171B24"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#292F3C" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="104" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding UserId}" Margin="14,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding LoginName}" Margin="14,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding DisplayName}" Margin="14,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" Text="{Binding RoleName}" Margin="14,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="{Binding StatusText}" Margin="14,0" VerticalAlignment="Center" Foreground="{Binding StatusForeground}" />
                                        <TextBlock Grid.Column="5" Text="{Binding CreatedAtText}" Margin="14,0" VerticalAlignment="Center" />
                                        <Button Grid.Column="6"
                                                Content="重置密码"
                                                Style="{StaticResource ResetButton}"
                                                IsEnabled="{Binding IsActive}"
                                                Click="ResetPasswordButton_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="EmptyText"
                               Grid.Row="1"
                               Text="暂无账号"
                               Foreground="#7E899B"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Background="#1C202B"
                    BorderBrush="#303645"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,6,6">
                <Button Content="关闭"
                        Width="86"
                        Height="30"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,24,0"
                        Background="#272C38"
                        Foreground="#E4E8EF"
                        BorderBrush="#3B4150"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="CloseButton_Click" />
            </Border>
        </Grid>
    </Border>
</Window>
