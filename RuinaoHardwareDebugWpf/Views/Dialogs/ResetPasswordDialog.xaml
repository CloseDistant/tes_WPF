<Window x:Class="RuinaoHardwareDebugWpf.Views.Dialogs.ResetPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="#1C202B"
            BorderBrush="#3A4050"
            BorderThickness="1"
            CornerRadius="8"
            MouseLeftButtonDown="DialogRoot_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.45" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Background="#202532"
                    CornerRadius="8,8,0,0"
                    BorderBrush="#303645"
                    BorderThickness="0,0,0,1"
                    Padding="20,15">
                <StackPanel>
                    <TextBlock Text="重置密码" FontSize="17" FontWeight="SemiBold" Foreground="#E4E8EF" />
                    <TextBlock x:Name="AccountText" Margin="0,4,0,0" FontSize="12" Foreground="#97A3B6" />
                </StackPanel>
            </Border>
            <Grid Grid.Row="1" Margin="24,20,24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="104" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="46" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="新密码" VerticalAlignment="Center" Foreground="#C8D0DE" />
                <PasswordBox x:Name="PasswordBox"
                             Grid.Column="1"
                             Height="32"
                             Background="#313644"
                             Foreground="#E4E8EF"
                             BorderBrush="#3B4150"
                             BorderThickness="1"
                             Padding="8,4"
                             VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="1" Text="确认新密码" VerticalAlignment="Center" Foreground="#C8D0DE" />
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Height="32"
                             Background="#313644"
                             Foreground="#E4E8EF"
                             BorderBrush="#3B4150"
                             BorderThickness="1"
                             Padding="8,4"
                             VerticalContentAlignment="Center" />
                <TextBlock x:Name="ErrorText"
                           Grid.Row="2"
                           Grid.ColumnSpan="2"
                           Margin="0,8,0,0"
                           Foreground="#E84E4F"
                           TextWrapping="Wrap" />
            </Grid>
            <Border Grid.Row="2"
                    Background="#1C202B"
                    CornerRadius="0,0,8,8"
                    BorderBrush="#303645"
                    BorderThickness="0,1,0,0"
                    Padding="18,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消"
                            MinWidth="86"
                            Height="34"
                            Margin="0,0,10,0"
                            Background="#272C38"
                            Foreground="#E4E8EF"
                            BorderBrush="#3A4050"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="CancelButton_Click" />
                    <Button Content="确认重置"
                            MinWidth="104"
                            Height="34"
                            Background="#D0903E"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ConfirmButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
