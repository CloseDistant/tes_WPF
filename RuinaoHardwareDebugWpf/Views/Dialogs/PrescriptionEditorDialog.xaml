<Window x:Class="RuinaoHardwareDebugWpf.Views.Dialogs.PrescriptionEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="660" Height="650" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAB2C2"/><Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="EditorBox" TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
            <Setter Property="Height" Value="31"/><Setter Property="FontSize" Value="13"/><Setter Property="Padding" Value="10,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#252A35"/><Setter Property="Foreground" Value="#757D8D"/>
                    <Setter Property="BorderBrush" Value="#303644"/><Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="EditorComboItem" TargetType="ComboBoxItem">
            <Setter Property="Height" Value="32"/><Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="#F2F4F8"/><Setter Property="Background" Value="#252B36"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#3A414F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#574126"/>
                                <Setter Property="Foreground" Value="#FFD59A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="EditorCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="31"/><Setter Property="Background" Value="#313644"/>
            <Setter Property="Foreground" Value="#F2F4F8"/><Setter Property="BorderBrush" Value="#485164"/>
            <Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="12,0,36,0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource EditorComboItem}"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboRoot" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Margin="12,0,4,0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    <Border Grid.Column="1" BorderBrush="#485164" BorderThickness="1,0,0,0">
                                        <Path Width="9" Height="5" Stretch="Fill" Fill="#D7DCE5"
                                              Data="M 0 0 L 4.5 5 L 9 0 Z" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent" BorderThickness="0" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade">
                                <Border Margin="0,2,0,0" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="220" Background="#252B36" BorderBrush="#485164" BorderThickness="1" CornerRadius="2">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                                  CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboRoot" Property="BorderBrush" Value="#6DAFF2"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboRoot" Property="BorderBrush" Value="{StaticResource Gold}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboRoot" Property="Background" Value="#252A35"/>
                                <Setter Property="Foreground" Value="#737B8A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="32"/><Setter Property="MinWidth" Value="88"/><Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#272C38"/><Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/><Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/><Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Border Background="#181D28" BorderBrush="#3A4150" BorderThickness="1" CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="52"/><RowDefinition Height="*"/><RowDefinition Height="58"/></Grid.RowDefinitions>
            <Border Background="#202632" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1"
                    CornerRadius="6,6,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="22,0">
                    <Button Content="×" DockPanel.Dock="Right" Width="30" Height="30" Background="Transparent"
                            Foreground="#AAB2C2" BorderThickness="0" FontSize="20" Click="CancelButton_Click"/>
                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="34,14,42,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="142"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="39"/><RowDefinition Height="39"/><RowDefinition Height="39"/><RowDefinition Height="39"/>
                        <RowDefinition Height="39"/><RowDefinition Height="39"/><RowDefinition Height="39"/><RowDefinition Height="39"/>
                        <RowDefinition Height="39"/><RowDefinition Height="39"/><RowDefinition Height="39"/><RowDefinition Height="39"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="处方名称" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorBox}"/>
                    <TextBlock Grid.Row="1" Text="适应症" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Indication, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorBox}"/>
                    <TextBlock Grid.Row="2" Text="刺激模式" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailableStimulationTypes}"
                              SelectedItem="{Binding StimulationType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorCombo}"/>
                    <TextBlock Grid.Row="3" Text="电流强度 (mA)" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Tag="decimal" Text="{Binding CurrentMilliamp, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource EditorBox}" PreviewTextInput="Decimal_PreviewTextInput" DataObject.Pasting="Numeric_Pasting"/>
                    <TextBlock Grid.Row="4" Text="模式" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" ItemsSource="{Binding DeliveryModes}"
                              SelectedItem="{Binding DeliveryMode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorCombo}"/>
                    <TextBlock Grid.Row="5" Text="总时长 (min)" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding TotalDurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource EditorBox}" PreviewTextInput="Integer_PreviewTextInput" DataObject.Pasting="Numeric_Pasting"/>
                    <TextBlock Grid.Row="6" Text="间隔时间 (min)" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding IntervalMinutesEntry, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsIntervalMode}" Style="{StaticResource EditorBox}"
                             PreviewTextInput="Integer_PreviewTextInput" DataObject.Pasting="Numeric_Pasting"/>
                    <TextBlock Grid.Row="7" Text="单次时长 (min)" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SessionDurationMinutesEntry, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsIntervalMode}" Style="{StaticResource EditorBox}"
                             PreviewTextInput="Integer_PreviewTextInput" DataObject.Pasting="Numeric_Pasting"/>
                    <TextBlock Grid.Row="8" Text="疗程" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Course, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorBox}"/>
                    <TextBlock Grid.Row="9" Text="渐升时间 (s)" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding RampUpSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource EditorBox}" PreviewTextInput="Integer_PreviewTextInput" DataObject.Pasting="Numeric_Pasting"/>
                    <TextBlock Grid.Row="10" Text="渐降时间 (s)" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding RampDownSeconds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource EditorBox}" PreviewTextInput="Integer_PreviewTextInput" DataObject.Pasting="Numeric_Pasting"/>
                    <TextBlock Grid.Row="11" Text="证据等级" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding EvidenceGrade, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorBox}"/>
                    <TextBlock Grid.Row="12" Grid.ColumnSpan="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                               FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Grid>
            </ScrollViewer>
            <Border Grid.Row="2" Background="#202632" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" CornerRadius="0,0,6,6">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                    <Button Content="取消" Style="{StaticResource DialogButton}" Margin="0,0,10,0" Click="CancelButton_Click"/>
                    <Button Content="保存" Style="{StaticResource DialogButton}" Background="{StaticResource Gold}" BorderBrush="{StaticResource Gold}" Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
