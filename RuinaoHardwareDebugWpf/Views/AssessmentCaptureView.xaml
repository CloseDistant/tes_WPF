<UserControl x:Class="RuinaoHardwareDebugWpf.Views.AssessmentCaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:RuinaoHardwareDebugWpf.Views.Controls"
             mc:Ignorable="d"
             Background="{StaticResource Bg}"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="760"
             d:DesignWidth="1280">
    <UserControl.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubText}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="StepDot" TargetType="Border">
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="9" />
            <Setter Property="CornerRadius" Value="4.5" />
            <Setter Property="Background" Value="#303645" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <Style x:Key="InfoPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="#242A36" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricBox" TargetType="Border">
            <Setter Property="Background" Value="#171B25" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="PrimaryCaptureButton" TargetType="Button">
            <Setter Property="Background" Value="#7C4A12" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="22,8" />
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9B5F18" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#623A0E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DevStepButton" TargetType="Button" BasedOn="{StaticResource PrimaryCaptureButton}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="#26364F" />
            <Setter Property="BorderBrush" Value="#4B77D8" />
        </Style>

        <Style x:Key="StartCaptureButton" TargetType="Button" BasedOn="{StaticResource TopButton}">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Padding" Value="22,8" />
            <Setter Property="Background" Value="#3A4252" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Visibility" Value="Hidden" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModuleProgressButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#202736" />
                                <Setter Property="BorderBrush" Value="#34415A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormFieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="FormComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="#111827" />
            <Setter Property="BorderBrush" Value="#3A4354" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource Text}" />
                        <Setter Property="Background" Value="#121722" />
                        <Setter Property="Padding" Value="12,8" />
                        <Setter Property="FontSize" Value="13" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="Transparent"
                                            BorderThickness="1"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter TextElement.Foreground="{StaticResource Text}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#20283A" />
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#D0903E" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2A2430" />
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#D0903E" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="#111827" />
            <Setter Property="BorderBrush" Value="#3A4354" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style x:Key="FormPickerButton" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#111827" />
            <Setter Property="BorderBrush" Value="#3A4354" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter Property="Background" Value="#151C29" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1C2433" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalendarNavButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter TargetName="Root" Property="Background" Value="#2F3542" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalendarDayButton" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter TargetName="Root" Property="Background" Value="#2F3542" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.25" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormOptionButton" TargetType="Button">
            <Setter Property="Background" Value="#151B27" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="#2D3648" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,11" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#20283A" />
                                <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2A2430" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuestionnaireOptionListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Width" Value="320" />
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Margin" Value="8,6" />
            <Setter Property="Padding" Value="13,9" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="#151B27" />
            <Setter Property="BorderBrush" Value="#2D3648" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OptionBorder"
                                Background="{TemplateBinding BorderBrush}"
                                CornerRadius="4"
                                Padding="1"
                                SnapsToDevicePixels="True">
                            <Border x:Name="OptionFill"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OptionBorder" Property="Background" Value="{StaticResource Gold}" />
                                <Setter TargetName="OptionFill" Property="Background" Value="#20283A" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="OptionBorder" Property="Background" Value="{StaticResource Gold}" />
                                <Setter TargetName="OptionFill" Property="Background" Value="#7C4A12" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuestionnaireOptionButton" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="58" />
            <Setter Property="Margin" Value="8,8" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="#151B27" />
            <Setter Property="BorderBrush" Value="#2D3648" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Border x:Name="OptionFill"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Margin="1"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OptionFill" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter TargetName="OptionFill" Property="Background" Value="#20283A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OptionFill" Property="Background" Value="#263247" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF" />
                                <Setter TargetName="OptionFill" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter TargetName="OptionFill" Property="BorderThickness" Value="2" />
                                <Setter TargetName="OptionFill" Property="Background" Value="#7C4A12" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuestionnaireScoreTickButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SubText}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,6" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Gold}" />
                                <Setter Property="Background" Value="#20283A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkbenchScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="#4B5568"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#D0903E" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkbenchScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="#10151F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="2,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource WorkbenchScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource WorkbenchScrollBar}" />

        <Style x:Key="WorkbenchScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="0" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Card}"
                Padding="16,10"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding WorkspaceTitleText}"
                           Foreground="{StaticResource Gold}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Style="{StaticResource InfoPill}">
                        <TextBlock Text="{Binding CurrentModuleBadgeText}" Foreground="{StaticResource Text}" FontSize="12" />
                    </Border>
                    <Border Style="{StaticResource InfoPill}" Background="#173323" BorderBrush="#285A37">
                        <TextBlock Text="{Binding WorkbenchStatusText}" Foreground="#7FE095" FontSize="12" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="286" />
            </Grid.ColumnDefinitions>

            <controls:AssessmentWorkflowSidebar Grid.Column="0" Margin="0,0,12,0" />

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Card}"
                        Padding="14"
                        Margin="0,0,12,0">
                    <Grid>
                        <Border Background="#0B0E14"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Margin="16,12,16,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SharedDisplayTitle}"
                                                   Foreground="{StaticResource Text}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="中央区域为公共显示容器：图片浏览、视频浏览、眼动校准等模块都复用此处；模块内部状态决定显示视频、图片或校准画布。"
                                                   Visibility="Collapsed"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </DockPanel>

                                <Grid Grid.Row="1" Margin="16,10">
                                    <Border Background="#11141D"
                                            BorderBrush="#252B37"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <Grid>
                                            <MediaElement x:Name="DemoMedia"
                                                          Source="{Binding DemoVideoUri}"
                                                          LoadedBehavior="Manual"
                                                          UnloadedBehavior="Stop"
                                                          Stretch="Uniform"
                                                          MediaEnded="DemoMedia_MediaEnded"
                                                          Visibility="{Binding IsDemoStage, Converter={StaticResource BoolToVisibilityConverter}}" />

                                            <Grid Visibility="{Binding IsEyeCalibrationStage, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  Background="#F5F7FA">
                                                <TextBlock Text="{Binding CurrentModule}"
                                                           Foreground="#5F6673"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Top"
                                                           Margin="18" />
                                                <Canvas Width="760"
                                                        Height="460"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding CalibrationText}"
                                                               Canvas.Left="{Binding CalibrationCanvasLeft}"
                                                               Canvas.Top="{Binding CalibrationCanvasTop}"
                                                               Foreground="#11141D"
                                                               FontSize="34"
                                                               FontWeight="SemiBold" />
                                                </Canvas>
                                                <Border Background="#E8ECF2"
                                                        BorderBrush="#CCD3DF"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="12,8"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,16,14">
                                                    <TextBlock Text="{Binding CalibrationStatusText}"
                                                               Foreground="#1F2530"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>

                                            <Grid Visibility="{Binding IsPictureBrowseStage, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Background="#11141D">
                                                <Grid Visibility="{Binding IsPictureShowing, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Image Source="{Binding PictureBrowseImagePath}"
                                                           Stretch="Uniform"
                                                           MaxWidth="780"
                                                           MaxHeight="500"
                                                           Margin="36,-18,36,18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                                </Grid>

                                                <Grid Visibility="{Binding IsPictureBlank, Converter={StaticResource BoolToVisibilityConverter}}" />

                                                <StackPanel HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding IsPictureResting, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding RestTitleText}"
                                                               Foreground="{StaticResource Text}"
                                                               FontSize="26"
                                                               FontWeight="SemiBold"
                                                               TextAlignment="Center"
                                                               Margin="0,0,0,14" />
                                                    <TextBlock Text="{Binding PictureBrowseRestText}"
                                                               Foreground="{StaticResource SubText}"
