                                                            Padding="32,10"
                                                            Click="StartSyncTestButton_Click"
                                                            Visibility="{Binding ShowSyncTestStartAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </StackPanel>

                                                <Border Background="#242A36"
                                                        BorderBrush="{StaticResource Gold}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="12,8"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,16,14"
                                                        Visibility="{Binding ShowSyncTestRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding SyncTestStatusText}"
                                                               Foreground="{StaticResource Text}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </Grid>

                                            <TextBlock Text="{Binding DevMainStageText}"
                                                       Foreground="{StaticResource Text}"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsGenericFallbackStage, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsCompletionStage, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding DevMainStageText}"
                                                           Foreground="{StaticResource Text}"
                                                           FontSize="22"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           Margin="0,0,0,18" />
                                                <Button Content="{Binding NextModule, StringFormat=进入 {0}}"
                                                        Style="{StaticResource PrimaryCaptureButton}"
                                                        MinWidth="180"
                                                        Command="{Binding GoNextModuleCommand}" />
                                            </StackPanel>
                                            <Border Background="#E8ECF2"
                                                    Visibility="Collapsed"
                                                    BorderBrush="#CCD3DF"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="10,6"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Margin="14,0,0,12">
                                                <TextBlock Text="{Binding DevHintText}"
                                                           Foreground="#1F2530"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,0,34">
                                                <Border Background="#242A36"
                                                        BorderBrush="{StaticResource Gold}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="12,8"
                                                        Margin="0,0,0,10"
                                                        MaxWidth="520"
                                                        Visibility="{Binding HasStageNotice, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding StageNoticeText}"
                                                               Foreground="{StaticResource Text}"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center" />
                                                </Border>
                                                <Button Content="{Binding PrimaryActionText}"
                                                        Style="{StaticResource PrimaryCaptureButton}"
                                                        MinWidth="180"
                                                        Padding="28,10"
                                                        Click="PlayDemoButton_Click"
                                                        Visibility="{Binding ShowDemoPlayAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <Button Content="{Binding EnterFaceCheckButtonText}"
                                                        Style="{StaticResource PrimaryCaptureButton}"
                                                        MinWidth="180"
                                                        Padding="28,10"
                                                        Click="StartCalibrationButton_Click"
                                                        Visibility="{Binding ShowFaceCheckAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <Button Content="{Binding SecondaryActionText}"
                                                        Style="{StaticResource PrimaryCaptureButton}"
                                                        MinWidth="180"
                                                        Padding="28,10"
                                                        Click="StartCalibrationButton_Click"
                                                        Visibility="{Binding ShowModuleStartAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="2"
                                        Visibility="Collapsed"
                                        Background="#11141D"
                                        BorderBrush="{StaticResource Line}"
                                        BorderThickness="1,1,0,0"
                                        Padding="12,8">
                                    <TextBlock Text="{Binding DemoVideoPath}"
                                               Foreground="{StaticResource SubText}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Visibility="Collapsed"
                        Background="#F5F7FA"
                        BorderBrush="#D9DEE7"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18"
                        Margin="0,0,12,0">
                    <Grid>
                        <TextBlock Text="正式校准显示区"
                                   Foreground="#5F6673"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top" />

                        <UniformGrid Rows="3"
                                     Columns="3"
                                     Width="520"
                                     Height="320"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                            <TextBlock Text="1" Foreground="#11141D" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="5" Foreground="#11141D" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="3" Foreground="#11141D" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="7" Foreground="#11141D" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="+" Foreground="#C93030" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="8" Foreground="#11141D" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="4" Foreground="#11141D" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="6" Foreground="#11141D" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="2" Foreground="#11141D" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </UniformGrid>

                        <Border Background="#E8ECF2"
                                BorderBrush="#CCD3DF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12,8"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="当前试次 1/4"
                                           Foreground="#1F2530"
                                           FontWeight="SemiBold"
                                           Margin="0,0,18,0" />
                                <TextBlock Text="固定顺序 8 点"
                                           Foreground="#5F6673" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="290" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Style="{StaticResource Card}"
                        Padding="14"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <Button Content="{Binding RefreshButtonText}"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource DeviceMenuButton}"
                                    Command="{Binding RefreshCameraDevicesCommand}"
                                    Click="RefreshCameraButton_Click" />
                            <TextBlock Text="{Binding CameraPanelTitleText}" Style="{StaticResource SectionTitle}" />
                        </DockPanel>
                        <Border Grid.Row="1"
                                Background="#0B0E14"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Margin="0,12,0,10">
                            <Grid>
                                <Image x:Name="CameraPreviewImage"
                                       Stretch="UniformToFill" />
                                <Rectangle Width="155"
                                           Height="170"
                                           Stroke="{StaticResource Gold}"
                                           StrokeThickness="2"
                                           StrokeDashArray="4 3"
                                           RadiusX="6"
                                           RadiusY="6"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding CameraPreviewPlaceholderText}"
                                           x:Name="CameraPreviewStatusText"
                                           Foreground="{StaticResource SubText}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,12" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Row="2">
                            <ComboBox ItemsSource="{Binding CameraDevices}"
                                      x:Name="CameraComboBox"
                                      SelectedItem="{Binding SelectedCameraDevice}"
                                      Background="#11141D"
                                      Foreground="#1F2530"
                                      BorderBrush="{StaticResource Line}"
                                      MinHeight="30"
                                      Margin="0,0,0,8"
                                      SelectionChanged="CameraComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#1F2530" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="{Binding CameraStatusText}"
                                       Foreground="{StaticResource Gold}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource Card}"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,10">
                            <Border DockPanel.Dock="Right"
                                    Background="#242A36"
                                    BorderBrush="{StaticResource Line}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,3">
                                <TextBlock Text="{Binding DevelopmentClickableText}"
                                           Foreground="{StaticResource SubText}"
                                           FontSize="11" />
                            </Border>
                            <TextBlock Text="{Binding ModuleFlowTitleText}"
                                       Style="{StaticResource SectionTitle}"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <ScrollViewer Grid.Row="1"
                                      Style="{StaticResource WorkbenchScrollViewer}">
                            <controls:AssessmentModuleProgressControl />
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}"
                        Visibility="Collapsed"
                        Padding="14"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="采集参数" Style="{StaticResource SectionTitle}" />
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                                <RowDefinition Height="28" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="图像保存频率" Style="{StaticResource MutedText}" />
                            <TextBlock Grid.Column="1" Text="1 秒 1 张 JPG" Foreground="{StaticResource Text}" />
                            <TextBlock Grid.Row="1" Text="大屏取景时间" Style="{StaticResource MutedText}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="3.0 s" Foreground="{StaticResource Text}" />
                            <TextBlock Grid.Row="2" Text="小屏取景时间" Style="{StaticResource MutedText}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="2.0 s" Foreground="{StaticResource Text}" />
                            <TextBlock Grid.Row="3" Text="人脸呈现时间" Style="{StaticResource MutedText}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="1.0 s" Foreground="{StaticResource Text}" />
                            <TextBlock Grid.Row="4" Text="长期不在范围" Style="{StaticResource MutedText}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="提醒并结束" Foreground="{StaticResource Text}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}"
                        Visibility="Collapsed"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="本地记录预览" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="session_start、trial_start、face_image、trial_end、session_end"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,8,0,10" />
                        <Border Background="#11141D"
                                BorderBrush="{StaticResource Line}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10">
                            <TextBlock Foreground="{StaticResource SubText}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="当前阶段只展示：开始时间、结束时间、试次配置、图片保存数量、失败原因与下一模块提示。" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Visibility="Collapsed"
                Style="{StaticResource Card}"
                Padding="14"
                Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="四次校准试次配置" Style="{StaticResource SectionTitle}" />
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,12,0,0">
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel>
                            <TextBlock Text="试次 1" Foreground="{StaticResource Gold}" FontWeight="SemiBold" />
                            <TextBlock Text="固定顺序 / 8 点" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            <TextBlock Text="1200 / 1000 / 800 ms" Foreground="{StaticResource Text}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel>
                            <TextBlock Text="试次 2" Foreground="{StaticResource Gold}" FontWeight="SemiBold" />
                            <TextBlock Text="随机显示 / 10 点" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            <TextBlock Text="800 / 1000 / 800 ms" Foreground="{StaticResource Text}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel>
                            <TextBlock Text="试次 3" Foreground="{StaticResource Gold}" FontWeight="SemiBold" />
                            <TextBlock Text="固定顺序 / 8 点" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            <TextBlock Text="800 / 1000 / 800 ms" Foreground="{StaticResource Text}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="试次 4" Foreground="{StaticResource Gold}" FontWeight="SemiBold" />
                            <TextBlock Text="随机显示 / 10 点" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                            <TextBlock Text="800 / 1000 / 1200 ms" Foreground="{StaticResource Text}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Popup x:Name="BasicInfoDatePickerPopup"
               PlacementTarget="{Binding ElementName=BasicInfoBirthDateButton}"
               Placement="Bottom"
               StaysOpen="True"
               AllowsTransparency="True">
            <Border Width="256"
                    Background="#202532"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10">
                <Border.Effect>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="16"
                                      ShadowDepth="0"
                                      Opacity="0.45" />
                </Border.Effect>
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <Button Content="‹"
                                DockPanel.Dock="Left"
                                Style="{StaticResource CalendarNavButton}"
                                Click="BasicInfoPreviousMonthButton_Click" />
                        <Button Content="›"
                                DockPanel.Dock="Right"
                                Style="{StaticResource CalendarNavButton}"
                                Click="BasicInfoNextMonthButton_Click" />
                        <TextBlock x:Name="BasicInfoCalendarTitleText"
                                   Foreground="{StaticResource Text}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <UniformGrid Columns="7" Rows="1" Margin="0,0,0,4">
                        <TextBlock Text="一" Foreground="{StaticResource SubText}" FontSize="12" TextAlignment="Center" />
                        <TextBlock Text="二" Foreground="{StaticResource SubText}" FontSize="12" TextAlignment="Center" />
                        <TextBlock Text="三" Foreground="{StaticResource SubText}" FontSize="12" TextAlignment="Center" />
                        <TextBlock Text="四" Foreground="{StaticResource SubText}" FontSize="12" TextAlignment="Center" />
                        <TextBlock Text="五" Foreground="{StaticResource SubText}" FontSize="12" TextAlignment="Center" />
                        <TextBlock Text="六" Foreground="{StaticResource SubText}" FontSize="12" TextAlignment="Center" />
                        <TextBlock Text="日" Foreground="{StaticResource SubText}" FontSize="12" TextAlignment="Center" />
                    </UniformGrid>
                    <UniformGrid x:Name="BasicInfoCalendarDaysGrid" Columns="7" Rows="6" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
