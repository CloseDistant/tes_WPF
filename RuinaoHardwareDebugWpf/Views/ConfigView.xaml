<UserControl x:Class="RuinaoHardwareDebugWpf.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C8CEDA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Bg}">
        <Border Width="520"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Background="#303139"
                Padding="24,20">
            <StackPanel>
                <TextBlock Text="设置"
                           Foreground="{StaticResource Text}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,24" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="最大电流 (mA)" Style="{StaticResource SettingLabel}" />
                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="最大电压 (V)" Style="{StaticResource SettingLabel}" />
                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}" />
                </Grid>

                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="默认运行时间 (s)" Style="{StaticResource SettingLabel}" />
                    <TextBox Grid.Column="1" Style="{StaticResource FieldBox}" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="软件版本" Style="{StaticResource SettingLabel}" />
                    <TextBlock Grid.Column="1" Text="V1.0.1" Style="{StaticResource SettingValue}" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="硬件版本" Style="{StaticResource SettingLabel}" />
                    <TextBlock Grid.Column="1" Text="V1.0.1" Style="{StaticResource SettingValue}" />
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="发布日期" Style="{StaticResource SettingLabel}" />
                    <TextBlock Grid.Column="1" Text="2026-06-10" Style="{StaticResource SettingValue}" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="SN" Style="{StaticResource SettingLabel}" />
                    <TextBlock Grid.Column="1" Text="12345678" Style="{StaticResource SettingValue}" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
