<UserControl x:Class="RuinaoHardwareDebugWpf.Views.DirectCurrentControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RuinaoHardwareDebugWpf"
             xmlns:controls="clr-namespace:RuinaoHardwareDebugWpf.Views.Controls"
             Background="#11141D">
    <Grid Margin="18,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="{Binding Localization.SynchronizedStartButtonText}"
                        Style="{StaticResource TopButton}"
                        Background="#27B65A"
                        Padding="24,8"
                        MinWidth="96"
                        Command="{Binding SynchronizedStartCommand}" />
                <Button Content="{Binding Localization.EmergencyStopButtonText}"
                        Style="{StaticResource TopButton}"
                        Background="{StaticResource Danger}"
                        Padding="24,8"
                        MinWidth="96"
                        Command="{Binding EmergencyStopCommand}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="{Binding Localization.BackText}"
                        Command="{Binding BackCommand}"
                        Background="Transparent"
                        Foreground="{StaticResource SubText}"
                        BorderBrush="#303645"
                        BorderThickness="1"
                        Padding="10,5"
                        Margin="0,0,16,0"
                        Cursor="Hand" />
                <StackPanel>
                    <TextBlock Text="{Binding Localization.DirectCurrentModeTitleText}"
                               Foreground="{StaticResource Gold}"
                               FontWeight="SemiBold"
                               FontSize="14" />
                    <TextBlock Text="{Binding Localization.TranscranialDirectCurrentText}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </DockPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Channels}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type local:ChannelConfig}">
                    <controls:StimulationChannelCard Margin="0,0,14,0"
                                                     Localization="{Binding DataContext.Localization, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     StartCommand="{Binding DataContext.StartChannelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     ShowCarrierFrequency="False"
                                                     ShowElectrodeDescription="False" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
