<UserControl x:Class="RuinaoHardwareDebugWpf.Views.StimulationTypeSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#11141D">
    <UserControl.Resources>
        <Style x:Key="StimulationTypeCard" TargetType="Button">
            <Setter Property="Background" Value="#1D222D" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="#303645" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter TargetName="CardBorder" Property="Background" Value="#212733" />
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="44,34">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
            <RowDefinition Height="330" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Localization.StimulationTypeTitleText}"
                       FontSize="24"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding Localization.StimulationTypeHintText}"
                       Foreground="{StaticResource SubText}"
                       FontSize="13"
                       Margin="0,8,0,0" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding TemporalInterferenceColumnWidth}" />
                <ColumnDefinition Width="{Binding CardSpacingColumnWidth}" />
                <ColumnDefinition Width="{Binding DirectCurrentColumnWidth}" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Visibility="{Binding TemporalInterferenceVisibility}"
                    Style="{StaticResource StimulationTypeCard}"
                    Command="{Binding OpenTemporalInterferenceCommand}">
                <Grid ClipToBounds="True">
                    <Viewbox Width="290" Height="250" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,28,-18" Opacity="0.22">
                        <Canvas Width="270" Height="250">
                            <Path Data="M 205,20 C 149,3 96,27 80,69 C 73,88 73,102 76,116 L 35,142 L 76,164 L 79,197 C 81,219 98,232 120,232 L 166,232 L 169,250"
                                  Stroke="#515866" StrokeThickness="8" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                            <Path Data="M 131,86 C 132,68 153,57 169,66 C 182,59 201,69 199,84 C 211,94 204,112 190,113 C 188,128 169,134 158,122 C 145,127 131,117 135,104 C 124,99 124,89 131,86 Z M 158,122 L 158,143"
                                  Stroke="#515866" StrokeThickness="7" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                        </Canvas>
                    </Viewbox>
                    <StackPanel Margin="38,36">
                    <Border Width="56" Height="56" HorizontalAlignment="Left" CornerRadius="9"
                            BorderBrush="#8C638D" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#684278" Offset="0" />
                                <GradientStop Color="#A27143" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Viewbox Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="44" Height="44">
                                <Path Data="M 22,5 C 12,5 6,12 7,21 C 7,27 11,31 16,34 L 16,40 M 22,5 C 33,5 39,13 37,23 C 36,29 32,33 27,35 L 26,40"
                                      Stroke="#F4F1F5" StrokeThickness="2.4" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                                <Path Data="M 16,16 C 16,12 21,11 24,14 C 28,12 32,16 30,20 C 33,23 30,27 27,27 C 26,31 21,31 20,27 C 16,29 13,25 15,22 C 12,20 13,16 16,16 Z M 20,27 L 20,33"
                                      Stroke="#F4F1F5" StrokeThickness="2.2" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round" Fill="Transparent" />
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <StackPanel Margin="0,32,0,0">
                        <TextBlock Text="{Binding Localization.TemporalInterferenceText}"
                                   FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="TI" Foreground="#9BA4B7" FontSize="13" Margin="0,9,0,0" />
                    </StackPanel>
                    </StackPanel>
                </Grid>
            </Button>

            <Button Grid.Column="2"
                    Visibility="{Binding DirectCurrentVisibility}"
                    Style="{StaticResource StimulationTypeCard}"
                    Command="{Binding OpenDirectCurrentCommand}">
                <Grid ClipToBounds="True">
                    <Canvas Width="260" Height="150" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Margin="0,0,30,16" Opacity="0.22">
                        <Line X1="65" Y1="20" X2="195" Y2="20" Stroke="#515866" StrokeThickness="7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        <Line X1="42" Y1="48" X2="218" Y2="48" Stroke="#515866" StrokeThickness="7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        <Line X1="20" Y1="76" X2="240" Y2="76" Stroke="#515866" StrokeThickness="7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        <Line X1="42" Y1="104" X2="218" Y2="104" Stroke="#515866" StrokeThickness="7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        <Line X1="65" Y1="132" X2="195" Y2="132" Stroke="#515866" StrokeThickness="7" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                    <StackPanel Margin="38,36">
                    <Border Width="56" Height="56" HorizontalAlignment="Left" CornerRadius="9"
                            BorderBrush="#8C638D" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#684278" Offset="0" />
                                <GradientStop Color="#A27143" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="−" FontSize="32" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="0,32,0,0">
                        <TextBlock Text="{Binding Localization.TranscranialDirectCurrentText}"
                                   FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="tDCS" Foreground="#9BA4B7" FontSize="13" Margin="0,9,0,0" />
                    </StackPanel>
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</UserControl>
