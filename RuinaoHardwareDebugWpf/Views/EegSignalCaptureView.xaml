<UserControl x:Class="RuinaoHardwareDebugWpf.Views.EegSignalCaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:renderers="clr-namespace:RuinaoHardwareDebugWpf.Views.Renderers"
             Focusable="True"
             PreviewKeyDown="EegPage_PreviewKeyDown"
             mc:Ignorable="d"
             Background="{StaticResource Bg}">
    <UserControl.Resources>
        <Style x:Key="EegToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#303645" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#485064" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#202530" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#20242D" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#303744" />
                                <Setter Property="Foreground" Value="#687286" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EegCaptureButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.38" />
                                <Setter Property="Foreground" Value="#C4CBD8" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EegParamBox" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel2}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <Style x:Key="EegScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="#4B5568"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EegScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="#10151F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="2,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EegScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource EegScrollBar}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34" />
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="12,0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Left">
                    <TextBlock Text="页面窗口"
                               Foreground="{StaticResource SubText}"
                               VerticalAlignment="Center" />
                    <Border Style="{StaticResource EegParamBox}">
                        <TextBlock Text="30 秒" Foreground="{StaticResource Text}" />
                    </Border>
                    <TextBlock Text="采样率"
                               Foreground="{StaticResource SubText}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                    <Border Style="{StaticResource EegParamBox}">
                        <TextBlock x:Name="SampleRateValueText"
                                   Text="1000Hz"
                                   Foreground="{StaticResource Text}" />
                    </Border>
                    <TextBlock Text="高通"
                               Foreground="{StaticResource SubText}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                    <Border Style="{StaticResource EegParamBox}">
                        <TextBlock x:Name="HighPassValueText"
                                   Text="0.5 Hz"
                                   Foreground="{StaticResource Text}" />
                    </Border>
                    <TextBlock Text="低通"
                               Foreground="{StaticResource SubText}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                    <Border Style="{StaticResource EegParamBox}">
                        <TextBlock x:Name="LowPassValueText"
                                   Text="80 Hz"
                                   Foreground="{StaticResource Text}" />
                    </Border>
                    <TextBlock Text="陷波"
                               Foreground="{StaticResource SubText}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                    <Border Style="{StaticResource EegParamBox}">
                        <TextBlock x:Name="NotchValueText"
                                   Text="50 Hz"
                                   Foreground="{StaticResource Text}" />
                    </Border>
                    <TextBlock Text="增益"
                               Foreground="{StaticResource SubText}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                    <Border Style="{StaticResource EegParamBox}">
                        <TextBlock x:Name="GainValueText"
                                   Text="×10"
                                   Foreground="{StaticResource Text}" />
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="ParameterSettingsButton"
                            Content="参数设置"
                            Style="{StaticResource EegToolbarButton}"
                            Click="ParameterSettingsButton_Click" />
                    <Button Content="参数模板"
                            Style="{StaticResource EegToolbarButton}"
                            Visibility="Collapsed" />
                    <Button Content="导出数据"
                            Style="{StaticResource EegToolbarButton}"
                            Click="ExportDataButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource Panel2}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="StartButton"
                            Content="▶ 开始采集"
                            Style="{StaticResource EegCaptureButton}"
                            Width="104"
                            Background="#3D9C55"
                            Command="{Binding StartCommand}" />
                    <Button x:Name="StopButton"
                            Content="■ 结束采集"
                            Style="{StaticResource EegCaptureButton}"
                            Width="104"
                            Margin="10,0,0,0"
                            Background="#B53D3F"
                            Command="{Binding StopCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="实验："
                               Foreground="{StaticResource SubText}"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="RecordNameTextBox"
                             Text="{Binding RecordName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Width="190"
                             Height="26"
                             Margin="4,0,20,0"
                             Background="#272C38"
                             Foreground="{StaticResource Text}"
                             BorderBrush="{StaticResource Line}"
                             VerticalContentAlignment="Center" />
                    <Border Background="#11141D"
                            BorderBrush="{StaticResource Gold}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="14,3">
                        <TextBlock x:Name="RecordingTimeText"
                                   Text="00:00:00"
                                   Foreground="{StaticResource Gold}"
                                   FontFamily="Consolas"
                                   FontSize="18" />
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="64 通道 / Page 模式"
                           Foreground="{StaticResource SubText}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{StaticResource Panel2}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="360" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{StaticResource Line}"
                        BorderThickness="0,0,1,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="34" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0"
                                   Background="{StaticResource Panel}"
                                   LastChildFill="True"
                                   Margin="0">
                            <TextBlock Text="🧠 电极阻抗图"
                                       Foreground="{StaticResource Text}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="12,0" />
                            <Button Content="↻"
                                    Width="28"
                                    Height="24"
                                    HorizontalAlignment="Right"
                                    DockPanel.Dock="Right"
                                    Background="{StaticResource Gold}"
                                    Foreground="{StaticResource Bg}"
                                    BorderBrush="#E0AA5A"
                                    BorderThickness="1"
                                    FontWeight="Bold"
                                    Margin="0,0,8,0" />
                        </DockPanel>
                        <Canvas x:Name="ElectrodeCanvas"
                                Grid.Row="1"
                                Background="#151923"
                                SizeChanged="ElectrodeCanvas_SizeChanged"
                                MouseLeave="ElectrodeCanvas_MouseLeave" />
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource Green}" />
                            <TextBlock Text=" &lt;5kΩ"
                                       Foreground="{StaticResource SubText}"
                                       Margin="4,0,16,0" />
                            <Ellipse Width="10" Height="10" Fill="{StaticResource Yellow}" />
                            <TextBlock Text=" 5-10kΩ"
                                       Foreground="{StaticResource SubText}"
                                       Margin="4,0,16,0" />
                            <Ellipse Width="10" Height="10" Fill="{StaticResource Danger}" />
                            <TextBlock Text=" >10kΩ"
                                       Foreground="{StaticResource SubText}"
                                       Margin="4,0,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        BorderBrush="{StaticResource Line}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Background="{StaticResource Panel}">
                            <TextBlock Text="⚡ 事件标记"
                                       Foreground="{StaticResource Text}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="12,0" />
                            <TextBlock x:Name="MarkerCountText"
                                       Text="0 个标记"
                                       Foreground="{StaticResource SubText}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Right"
                                       Margin="0,0,12,0" />
                        </DockPanel>
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="MarkerListPanel" Margin="8" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1"
                    Background="{StaticResource Bg}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="28" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>
                    <ScrollViewer x:Name="WaveformScrollViewer"
                                  Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  SizeChanged="WaveformScrollViewer_SizeChanged">
                        <renderers:EegWaveformRenderSurface x:Name="WaveformSurface"
                                                            ClipToBounds="True"
                                                            HorizontalAlignment="Stretch"
                                                            SizeChanged="WaveformSurface_SizeChanged" />
                    </ScrollViewer>

                    <Canvas x:Name="TimeAxisCanvas"
                            Grid.Row="1"
                            Background="#0D1017"
                            ClipToBounds="True"
                            SizeChanged="TimeAxisCanvas_SizeChanged" />

                    <Grid Grid.Row="2"
                          Background="{StaticResource Panel2}"
                          Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="快捷键标注"
                                   Foreground="{StaticResource SubText}"
                                   VerticalAlignment="Center"
                                   Margin="12,0" />
                        <StackPanel x:Name="ShortcutPanel"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Line}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="FooterHintText"
                       Text="Page 模式：30 秒一页，扫描线从左到右覆盖刷新。采集中可按 F8-F12 添加事件标记。"
                       Foreground="{StaticResource SubText}"
                       VerticalAlignment="Center"
                       Margin="12,0" />
        </Border>
    </Grid>
</UserControl>
