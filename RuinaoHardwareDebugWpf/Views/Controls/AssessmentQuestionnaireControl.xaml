<UserControl x:Class="RuinaoHardwareDebugWpf.Views.Controls.AssessmentQuestionnaireControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#11141D">
    <ScrollViewer x:Name="QuestionnaireScrollViewer"
                  VerticalScrollBarVisibility="Disabled"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Width="{Binding ActualWidth, ElementName=QuestionnaireScrollViewer}" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#171B25"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="36,30"
                    Margin="56,18,56,12"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    MaxWidth="1180">
                <Grid HorizontalAlignment="Stretch" MaxWidth="1020">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="{Binding QuestionnaireProgressText}"
                               Foreground="{StaticResource Gold}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,0,0,16" />
                    <TextBlock Grid.Row="1"
                               Text="{Binding CurrentQuestionnaireQuestion.Text}"
                               Foreground="{StaticResource Text}"
                               FontSize="{Binding CurrentQuestionnaireQuestion.QuestionFontSize}"
                               FontWeight="SemiBold"
                               LineHeight="{Binding CurrentQuestionnaireQuestion.QuestionLineHeight}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="900"
                               Margin="0,0,0,26" />

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding CurrentQuestionnaireQuestion.OptionItems}"
                                  MaxWidth="{Binding CurrentQuestionnaireQuestion.OptionPanelWidth}"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentQuestionnaireQuestion.IsZeroToTenQuestion}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="{Binding DataContext.CurrentQuestionnaireQuestion.OptionColumnCount, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectQuestionnaireOptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Text}"
                                        Style="{DynamicResource QuestionnaireOptionButton}">
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" TextAlignment="Center" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="3" MaxWidth="900" HorizontalAlignment="Stretch" Margin="0,2,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentQuestionnaireQuestion.IsZeroToTenQuestion}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#111827" BorderBrush="#2D3648" BorderThickness="1" CornerRadius="4" Padding="14,9" Margin="0,0,0,14">
                            <TextBlock Text="{Binding CurrentQuestionnaireQuestion.AnswerDisplayText}" Foreground="{StaticResource Text}" FontSize="20" FontWeight="SemiBold" TextAlignment="Center" />
                        </Border>
                        <Slider Grid.Row="1" Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding CurrentQuestionnaireQuestion.ScoreValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Foreground="{StaticResource Gold}" Background="#2D3648" Height="34" />
                        <ItemsControl Grid.Row="2" Margin="10,0" ItemsSource="{Binding CurrentQuestionnaireQuestion.AnswerOptions}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="11" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}"
                                            Command="{Binding DataContext.SelectQuestionnaireOptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{DynamicResource QuestionnaireScoreTickButton}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center" MaxWidth="760" Margin="28,0,28,18">
                <Border Background="#3A2230" BorderBrush="#8A3B4A" BorderThickness="1" CornerRadius="4" Padding="18,8" Margin="0,0,0,12"
                        HorizontalAlignment="Center" MaxWidth="560"
                        Visibility="{Binding HasQuestionnaireValidationMessage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding QuestionnaireValidationMessage}" Foreground="#FFB5C0" TextWrapping="Wrap" TextAlignment="Center" />
                </Border>
                <Grid Width="520" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{Binding QuestionnairePreviousButtonText}" Command="{Binding PreviousQuestionnaireQuestionCommand}"
                            IsEnabled="{Binding CanGoPreviousQuestionnaireQuestion}" Style="{DynamicResource StartCaptureButton}" Padding="22,9" />
                    <Button Grid.Column="2" Content="{Binding QuestionnaireNextButtonText}" Command="{Binding NextQuestionnaireQuestionCommand}"
                            Style="{DynamicResource PrimaryCaptureButton}" Padding="28,10"
                            Visibility="{Binding ShowQuestionnaireNextButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Grid.Column="2" Content="{Binding QuestionnaireSubmitButtonText}" Command="{Binding SubmitQuestionnaireCommand}"
                            Style="{DynamicResource PrimaryCaptureButton}" Padding="28,10"
                            Visibility="{Binding ShowQuestionnaireSubmitButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
