<UserControl x:Class="RuinaoHardwareDebugWpf.Views.TiControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RuinaoHardwareDebugWpf"
             xmlns:controls="clr-namespace:RuinaoHardwareDebugWpf.Views.Controls"
             Background="#11141D">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#171B25"
                BorderBrush="#242A36"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="18,8">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Button Content="{Binding Localization.BackText}"
                            Command="{Binding BackCommand}"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            Foreground="{StaticResource SubText}"
                            BorderBrush="#303645"
                            BorderThickness="1"
                            Padding="10,5"
                            Margin="0,0,0,12"
                            Cursor="Hand" />
                    <TextBlock Text="{Binding Localization.ModeTitleText}"
                               Foreground="{StaticResource Gold}"
                               FontWeight="SemiBold"
                               FontSize="16" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:TiGroup}">
                            <Border Tag="{Binding}">
                                <Border.InputBindings>
                                    <MouseBinding Gesture="LeftClick"
                                                  Command="{Binding DataContext.SelectGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}" />
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                        <Setter Property="Padding" Value="7,5" />
                                        <Setter Property="Margin" Value="0,0,0,4" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                                                <Setter Property="BorderThickness" Value="1.5" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,3">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource Gold}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   DockPanel.Dock="Left" />
                                        <TextBlock Text="{Binding DeltaText}"
                                                   Foreground="{StaticResource SubText}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding Channels}"
                                                  ItemTemplate="{StaticResource ChannelMiniTemplate}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding Localization.SynchronizedStartButtonText}"
                            Style="{StaticResource TopButton}"
                            Background="#27B65A"
                            Padding="24,8"
                            MinWidth="96"
                            Command="{Binding StartCommand}" />
                    <Button Content="{Binding Localization.EmergencyStopButtonText}"
                            Style="{StaticResource TopButton}"
                            Background="{StaticResource Danger}"
                            Padding="24,8"
                            MinWidth="96"
                            Command="{Binding EmergencyStopCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding SelectedGroup.Title}"
                           Foreground="{StaticResource Gold}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           DockPanel.Dock="Left" />
            </DockPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedGroup.Channels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ChannelConfig}">
                        <controls:StimulationChannelCard Margin="0,0,14,0"
                                                         Localization="{Binding DataContext.Localization, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         StartCommand="{Binding DataContext.StartChannelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         ShowCarrierFrequency="True"
                                                         ShowElectrodeDescription="True" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
