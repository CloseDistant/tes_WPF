<UserControl x:Class="RuinaoHardwareDebugWpf.Views.TiControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:RuinaoHardwareDebugWpf"
             mc:Ignorable="d"
             Background="#11141D">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#171B25"
                    BorderBrush="#242A36"
                    BorderThickness="0,0,1,0"
>
                <DockPanel Margin="18,8">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <DockPanel>
                            <TextBlock Text="{Binding Localization.ModeTitleText}"
                                       Foreground="{StaticResource Gold}"
                                       FontWeight="SemiBold"
                                       FontSize="16" />
                        </DockPanel>
                        <TextBlock Text="{Binding Localization.ChannelHintText}"
                                   Foreground="{StaticResource SubText}"
                                   FontSize="12"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:TiGroup}">
                                <Border Tag="{Binding}">
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.SelectGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                            <Setter Property="Padding" Value="7,5" />
                                            <Setter Property="Margin" Value="0,0,0,4" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                                                    <Setter Property="BorderThickness" Value="1.5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,3">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource Gold}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding DeltaText}"
                                                       Foreground="{StaticResource SubText}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Right" />
                                        </DockPanel>
                                        <ItemsControl ItemsSource="{Binding Channels}"
                                                      ItemTemplate="{StaticResource ChannelMiniTemplate}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>


            <Grid Grid.Column="1" Margin="18,16"
>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,14">
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="{Binding Localization.StartButtonText}"
                                Style="{StaticResource TopButton}"
                                Background="#27B65A"
                                Padding="24,8"
                                MinWidth="86"
                                Command="{Binding StartCommand}" />
                        <Button Content="{Binding Localization.EmergencyStopButtonText}"
                                Style="{StaticResource TopButton}"
                                Background="{StaticResource Danger}"
                                Padding="24,8"
                                MinWidth="96"
                                Command="{Binding EmergencyStopCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedGroup.Title}"
                               Foreground="{StaticResource Gold}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               DockPanel.Dock="Left" />
                </DockPanel>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedGroup.Channels}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:ChannelConfig}">
                            <Border Style="{StaticResource SelectedCard}" Margin="0,0,14,0" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="210" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding AccentBrush}" />
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DataContext.Localization.RemainingTimeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                       Foreground="{StaticResource SubText}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0" />
                                            <Border Background="#303644" CornerRadius="5" Padding="14,6">
                                                <TextBlock Text="{Binding RemainingTime}"
                                                           FontFamily="Consolas"
                                                           FontSize="15"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Margin="0,22,0,14">
                                        <TextBlock Text="{Binding DataContext.Localization.StatusMonitorLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" />
                                        <Border Background="#171B25" Margin="0,10,0,0" Padding="18,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding AnodeTempC}" FontSize="46" FontWeight="Bold" Foreground="{StaticResource Green}" />
                                                    <TextBlock Text="{Binding DataContext.Localization.AnodeTempLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding CathodeTempC}" FontSize="46" FontWeight="Bold" Foreground="{StaticResource Green}" />
                                                    <TextBlock Text="{Binding DataContext.Localization.CathodeTempLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="{Binding ImpedanceOhm}" FontSize="46" FontWeight="Bold" Foreground="{StaticResource Yellow}" />
                                                    <TextBlock Text="{Binding DataContext.Localization.ImpedanceLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <Grid Grid.Row="2" Margin="0,4,0,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.88*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="1.18*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="40" />
                                            <RowDefinition Height="40" />
                                            <RowDefinition Height="40" />
                                            <RowDefinition Height="40" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="*" MinWidth="64" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.AmplitudeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Margin="0,3" Style="{StaticResource FieldBox}" Text="{Binding CurrentMA, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Column="2" Text="mA" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                                        </Grid>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="*" MinWidth="64" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.RampUpLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Margin="0,3" Style="{StaticResource FieldBox}" Text="{Binding RampUpS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Column="2" Text="s" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                                        </Grid>

                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="*" MinWidth="64" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.RampDownLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Margin="0,3" Style="{StaticResource FieldBox}" Text="{Binding RampDownS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Column="2" Text="s" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                                        </Grid>

                                        <Grid Grid.Row="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="56" />
                                                <ColumnDefinition Width="*" MinWidth="64" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.PolarityLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Margin="0,3" Style="{StaticResource FieldBox}" Text="{Binding Polarity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>

                                        <Grid Grid.Column="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52" />
                                                <ColumnDefinition Width="*" MinWidth="150" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.ModeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            <UniformGrid Grid.Column="1" Rows="1" Columns="2" Margin="0,3" MinWidth="150">
                                                <ToggleButton Content="{Binding DataContext.Localization.IntervalModeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              Style="{StaticResource ModeToggleButton}"
                                                              IsChecked="{Binding IsIntervalMode, Mode=TwoWay}" />
                                                <ToggleButton Content="{Binding DataContext.Localization.ContinuousModeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              Style="{StaticResource ModeToggleButton}"
                                                              IsChecked="{Binding IsContinuousMode, Mode=TwoWay}" />
                                            </UniformGrid>
                                        </Grid>

                                        <Grid Grid.Row="1" Grid.Column="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" MinWidth="64" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.DurationLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Margin="0,3" Style="{StaticResource FieldBox}" Text="{Binding DurationS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Column="2" Text="s" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                                        </Grid>

                                        <Grid Grid.Row="2" Grid.Column="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" MinWidth="64" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.IntervalTimeLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Margin="0,3" Style="{StaticResource FieldBox}" Text="{Binding IntervalS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Column="2" Text="s" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                                        </Grid>

                                        <Grid Grid.Row="3" Grid.Column="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" MinWidth="64" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.CarrierFrequencyLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Margin="0,3" Style="{StaticResource FieldBox}" Text="{Binding FrequencyHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Grid.Column="2" Text="Hz" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                                        </Grid>
                                    </Grid>

                                    <Border Grid.Row="3" Background="#141823" Padding="16" BorderBrush="#242A36" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="22" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding DataContext.Localization.WaveformLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="{StaticResource SubText}" />
                                            <Border Grid.Row="1"
                                                    Margin="0,10,0,0"
                                                    Background="#111722"
                                                    BorderBrush="#242A36"
                                                    BorderThickness="1" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="4" Margin="0,14,0,0">
                                        <TextBlock Foreground="{StaticResource SubText}">
                                            <Run Text="{Binding DataContext.Localization.ElectrodeLabel, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" />
                                            <Run Text="{Binding Anode}" />
                                            <Run Text=" / " />
                                            <Run Text="{Binding Cathode}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>

    </Grid>
</UserControl>


