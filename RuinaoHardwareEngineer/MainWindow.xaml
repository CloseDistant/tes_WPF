<Window x:Class="RuinaoHardwareEngineer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="睿脑 tES 硬件工程师工具"
        Width="1120"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="tES 背板工程师工具"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock Text="第一阶段：设备发现、联机、握手、断联"
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="14,8"
                    CornerRadius="18"
                    Background="#E8EEFF"
                    VerticalAlignment="Center">
                <TextBlock x:Name="StateBadgeText"
                           Text="未联机"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="1.4*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="设备" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock x:Name="DeviceNameText" Text="正在检测…" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="硬件 ID" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock x:Name="HardwareIdText" Text="VID_04B4 / PID_00F1" Margin="0,5,0,0" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Windows 驱动" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock x:Name="DriverStatusText" Text="未知" Margin="0,5,0,0" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="协议" Foreground="{StaticResource MutedBrush}" />
                    <TextBlock Text="V1.4 / usbtest兼容" Margin="0,5,0,0" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                Padding="18"
                Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="版本字段" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="ProtocolVersionTextBox" Text="0x01" Width="100" FontFamily="Consolas" />
                    <TextBlock Text="超时(ms)" VerticalAlignment="Center" Margin="24,0,8,0" />
                    <TextBox x:Name="TimeoutTextBox" Text="1000" Width="110" FontFamily="Consolas" />
                </StackPanel>

                <WrapPanel Grid.Row="1" Margin="0,14,0,0">
                    <Button x:Name="RefreshButton" Content="刷新设备" Click="RefreshButton_Click" />
                    <Button x:Name="ConnectButton" Content="联机" Click="ConnectButton_Click" Background="#E8EEFF" />
                    <Button x:Name="HandshakeButton" Content="握手" Click="HandshakeButton_Click" Background="#DDF6EA" />
                    <Button x:Name="DisconnectButton" Content="断联" Click="DisconnectButton_Click" Margin="0" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="18,14,18,10">
                    <TextBlock Text="通信日志" FontSize="16" FontWeight="SemiBold" />
                    <Button Content="清空"
                            HorizontalAlignment="Right"
                            MinHeight="28"
                            Padding="12,3"
                            Margin="0"
                            Click="ClearLogButton_Click" />
                </Grid>
                <ListBox Grid.Row="1"
                         x:Name="LogList"
                         ItemsSource="{Binding LogItems}"
                         BorderThickness="0"
                         Background="#FBFCFE"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Time}" FontFamily="Consolas" Foreground="#657089" />
                                <TextBlock Grid.Column="1" Text="{Binding Category}" FontFamily="Consolas" FontWeight="Bold" Foreground="#2357D9" />
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Hex}"
                                               Visibility="{Binding HexVisibility}"
                                               Margin="0,4,0,0"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="#3E4A62"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
