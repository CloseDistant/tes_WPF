<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:RuinaoSoftwareWpf">
        <SolidColorBrush x:Key="Bg" Color="#11141D" />
        <SolidColorBrush x:Key="Panel" Color="#1C202B" />
        <SolidColorBrush x:Key="Panel2" Color="#171B25" />
        <SolidColorBrush x:Key="Line" Color="#303645" />
        <SolidColorBrush x:Key="Gold" Color="#D0903E" />
        <SolidColorBrush x:Key="Text" Color="#E4E8EF" />
        <SolidColorBrush x:Key="SubText" Color="#8E96A8" />
        <SolidColorBrush x:Key="Green" Color="#5DDA77" />
        <SolidColorBrush x:Key="Yellow" Color="#FFD84D" />
        <SolidColorBrush x:Key="Danger" Color="#E84E4F" />
        <FontFamily x:Key="UiFontFamily">Microsoft YaHei UI</FontFamily>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- 普通界面统一使用微软雅黑 UI；局部显式字体（如 EEG 的 Consolas）继续优先。 -->
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="UserControl">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>
        <Style TargetType="ToolTip">
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>

        <!-- 全局灰色滚动条：所有未定义局部样式的列表和滚动区域默认使用。 -->
        <Style x:Key="AppScrollBarThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#4B5568" CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#D0903E" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="#10151F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="2,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource AppScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource AppScrollBar}" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        </Style>

        <Style x:Key="NavText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubText}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="18,10" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="SelectedCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>

        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="#313644" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="#3B4150" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="TopButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="22,8" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="DeviceMenuButton" TargetType="Button">
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="#3A4050" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ToolbarDropDownButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="StimulationFieldBox" TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="StimulationComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#303746" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3329" />
                    <Setter Property="Foreground" Value="{StaticResource Gold}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StimulationComboBox" TargetType="ComboBox">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="#313644" />
            <Setter Property="BorderBrush" Value="#3B4150" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource StimulationComboBoxItem}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="OuterBorder"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Margin="10,0,4,0"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Grid.Column="1"
                                                      Width="9"
                                                      Height="5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{StaticResource Gold}"
                                                      Data="M 0 0 L 4.5 5 L 9 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource Gold}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        Margin="0,3,0,0"
                                        Background="#202531"
                                        BorderBrush="{StaticResource Gold}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ScrollViewer MaxHeight="180">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ToolbarDropDownItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ItemBackground"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#292F3C" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#343C4B" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#171B24" />
                    <Setter Property="Foreground" Value="#667181" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BackNavigationButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1F2A" />
            <Setter Property="Foreground" Value="#DDE2EA" />
            <Setter Property="BorderBrush" Value="#3A4252" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Padding" Value="10,0,12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <DockPanel Margin="{TemplateBinding Padding}">
                                <Border x:Name="IconSurface"
                                        DockPanel.Dock="Left"
                                        Width="22"
                                        Height="22"
                                        Margin="0,0,8,0"
                                        Background="#242B38"
                                        BorderBrush="#414A5B"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <TextBlock Text="&#xE72B;"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="12"
                                               Foreground="{TemplateBinding Foreground}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#242A36" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#B78231" />
                                <Setter TargetName="IconSurface" Property="Background" Value="#332A1E" />
                                <Setter TargetName="IconSurface" Property="BorderBrush" Value="#B78231" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#302819" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D59B3D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#151923" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#2B3240" />
                                <Setter TargetName="IconSurface" Property="Background" Value="#1B202B" />
                                <Setter TargetName="IconSurface" Property="BorderBrush" Value="#2B3240" />
                                <Setter Property="Foreground" Value="#596474" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleButton" TargetType="Button">
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="#3A4050" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="ModeToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="#3A4050" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,6" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource Gold}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ChannelMiniTemplate" DataType="{x:Type local:ChannelConfig}">
            <Grid Height="20" Margin="0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="{Binding AccentBrush}" />
                <Border Grid.Column="1"
                        Background="#2B303D"
                        CornerRadius="4"
                        Padding="6,1"
                        Margin="0,0,6,0">
                    <DockPanel>
                        <Ellipse Width="7" Height="7" Fill="{StaticResource Green}" DockPanel.Dock="Right" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Run Text="+ " Foreground="{StaticResource Gold}" />
                            <Run Text="{Binding Anode}" />
                        </TextBlock>
                    </DockPanel>
                </Border>
                <Border Grid.Column="2"
                        Background="#2B303D"
                        CornerRadius="4"
                        Padding="6,1">
                    <DockPanel>
                        <Ellipse Width="7" Height="7" Fill="{StaticResource Green}" DockPanel.Dock="Right" VerticalAlignment="Center" />
                        <TextBlock FontSize="12" VerticalAlignment="Center">
                            <Run Text="- " Foreground="#7EB2FF" />
                            <Run Text="{Binding Cathode}" />
                        </TextBlock>
                    </DockPanel>
                </Border>
            </Grid>
        </DataTemplate>
</ResourceDictionary>
