<Window x:Class="RuinaoSoftwareWpf.Views.EegMarkerSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="事件标记"
        Width="500"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter Property="Background" Value="#2F3542" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#202634" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="#111722" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="#111722" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="#111722"
                                    BorderBrush="{StaticResource Line}"
                                    BorderThickness="1"
                                    CornerRadius="3" />
                            <ContentPresenter Margin="10,0,28,0"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}" />
                            <TextBlock Text="▾"
                                       Foreground="{StaticResource SubText}"
                                       FontSize="12"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <ToggleButton Focusable="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Width="{TemplateBinding ActualWidth}"
                                        Background="{StaticResource Panel}"
                                        BorderBrush="{StaticResource Line}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Margin="0,3,0,0">
                                    <ScrollViewer MaxHeight="180">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="{StaticResource Panel}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#272C38" />
                    <Setter Property="Foreground" Value="{StaticResource Gold}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#303645" />
                    <Setter Property="Foreground" Value="{StaticResource Gold}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="#4B5568"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="#10151F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="2,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DialogScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Panel2}"
            BorderBrush="{StaticResource Line}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="16,0">
                    <Button Content="×"
                            DockPanel.Dock="Right"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            Foreground="{StaticResource SubText}"
                            BorderThickness="0"
                            FontSize="18"
                            Click="CancelButton_Click" />
                    <TextBlock Text="事件标记"
                               Foreground="{StaticResource Text}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="18,18,18,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="26" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="86" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="标签名称" Style="{StaticResource LabelText}" />
                <TextBox x:Name="NameTextBox"
                         Grid.Row="0"
                         Grid.Column="1"
                         Style="{StaticResource InputTextBox}"
                         ToolTip="请输入标签名称" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="标签颜色" Style="{StaticResource LabelText}" />
                <ComboBox x:Name="ColorComboBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Style="{StaticResource DarkComboBox}"
                          SelectedIndex="0" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="快捷键" Style="{StaticResource LabelText}" />
                <TextBox x:Name="ShortcutTextBox"
                         Grid.Row="2"
                         Grid.Column="1"
                         Style="{StaticResource InputTextBox}"
                         IsReadOnly="True"
                         PreviewKeyDown="ShortcutTextBox_PreviewKeyDown"
                         ToolTip="点击后按下快捷键" />

                <StackPanel Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Content="添加"
                            Style="{StaticResource DialogButton}"
                            Click="AddButton_Click" />
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource Danger}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="4"
                           Grid.ColumnSpan="2"
                           Text="标签列表"
                           Foreground="{StaticResource SubText}"
                           FontSize="14"
                           VerticalAlignment="Center" />

                <Border Grid.Row="5"
                        Grid.ColumnSpan="2"
                        Background="#111722"
                        BorderBrush="{StaticResource Line}"
                        BorderThickness="1"
                        CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Background="{StaticResource Panel}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="名称" Foreground="{StaticResource SubText}" Margin="12,0,0,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="颜色" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="快捷键" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TagListPanel" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,4,4">
                <Button Content="确定"
                        Style="{StaticResource DialogButton}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="OkButton_Click" />
            </Border>
        </Grid>
    </Border>
</Window>
