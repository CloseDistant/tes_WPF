<UserControl x:Class="RuinaoSoftwareWpf.Views.FemSimulationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:RuinaoSoftwareWpf"
             mc:Ignorable="d"
             Background="#11141D">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#1C202B"
                    BorderBrush="#242A36"
                    BorderThickness="0,0,1,0"
>
                <DockPanel Margin="18,14">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid Height="44" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#2D303A"
                                    CornerRadius="4,0,0,4"
                                    Padding="10,7"
                                    Margin="0,0,3,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding Context.Localization.FemStep1Text}" Foreground="{StaticResource SubText}" FontSize="12" />
                                    <TextBlock Text="{Binding Context.Localization.FemLoadModelText}" FontSize="13" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="#20242E"
                                    CornerRadius="0,4,4,0"
                                    Padding="10,7">
                                <StackPanel>
                                    <TextBlock Text="{Binding Context.Localization.FemStep2Text}" Foreground="{StaticResource SubText}" FontSize="12" />
                                    <TextBlock Text="{Binding Context.Localization.FemVisualizationText}" FontSize="13" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Border Style="{StaticResource Card}" Padding="14">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,20">
                                <TextBlock Text="{Binding Context.Localization.FemLoadHeadModelText}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Text}" />
                                <Button Content="{Binding Context.Localization.FemChooseFileText}"
                                        Style="{StaticResource ToggleButton}"
                                        DockPanel.Dock="Right"
                                        Padding="12,6" />
                            </DockPanel>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Context.Localization.FemCoronalSliceText}" VerticalAlignment="Center" Foreground="{StaticResource Text}" />
                                <Button Grid.Column="1" Content="-" Style="{StaticResource ToggleButton}" Padding="0" />
                                <TextBox Grid.Column="2" Text="12" Style="{StaticResource FieldBox}" HorizontalContentAlignment="Center" Margin="8,0" />
                                <Button Grid.Column="3" Content="+" Style="{StaticResource ToggleButton}" Padding="0" />
                            </Grid>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Context.Localization.FemSagittalSliceText}" VerticalAlignment="Center" Foreground="{StaticResource Text}" />
                                <Button Grid.Column="1" Content="-" Style="{StaticResource ToggleButton}" Padding="0" />
                                <TextBox Grid.Column="2" Text="12" Style="{StaticResource FieldBox}" HorizontalContentAlignment="Center" Margin="8,0" />
                                <Button Grid.Column="3" Content="+" Style="{StaticResource ToggleButton}" Padding="0" />
                            </Grid>

                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="32" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Context.Localization.FemAxialSliceText}" VerticalAlignment="Center" Foreground="{StaticResource Text}" />
                                <Button Grid.Column="1" Content="-" Style="{StaticResource ToggleButton}" Padding="0" />
                                <TextBox Grid.Column="2" Text="12" Style="{StaticResource FieldBox}" HorizontalContentAlignment="Center" Margin="8,0" />
                                <Button Grid.Column="3" Content="+" Style="{StaticResource ToggleButton}" Padding="0" />
                            </Grid>

                            <Button Content="{Binding Context.Localization.FemGenerateMontageText}"
                                    Style="{StaticResource TopButton}"
                                    Background="#555862"
                                    Margin="0"
                                    Padding="12,8" />
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>


            <Grid Grid.Column="1"
                  Margin="14"
                  Background="#20242B"
>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,8">
                    <Button Content="2D"
                            Style="{StaticResource ToggleButton}"
                            Padding="14,7"
                            Margin="0,0,8,0" />
                    <Button Content="3D"
                            Style="{StaticResource ToggleButton}"
                            Background="#4A3B28"
                            BorderBrush="#5E4930"
                            Padding="14,7" />
                </StackPanel>

                <Viewbox Grid.Row="1" Stretch="Uniform" Margin="80,40">
                    <Border Width="760"
                            Height="400"
                            Background="Black"
                            BorderBrush="#E5E5E5"
                            BorderThickness="2"
                            Padding="12">
                        <UniformGrid Rows="2" Columns="4">
                            <Border Margin="5" Background="#111">
                                <Grid>
                                    <Ellipse Stroke="#D7D7D7" StrokeThickness="8" Fill="#444" Margin="12" />
                                    <Ellipse Stroke="#7A7A7A" StrokeThickness="4" Fill="#9A9A9A" Margin="32,28" />
                                    <Path Data="M95,120 L115,82 L132,120 Z" Fill="White" />
                                    <TextBlock Text="A" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" />
                                </Grid>
                            </Border>
                            <Border Margin="5" Background="#111">
                                <Grid>
                                    <Ellipse Stroke="#D7D7D7" StrokeThickness="8" Fill="#4A4A4A" Margin="12" />
                                    <Ellipse Stroke="#7A7A7A" StrokeThickness="4" Fill="#A6A6A6" Margin="30,24" />
                                    <Path Data="M120,142 L138,100 L154,142 Z" Fill="White" />
                                    <TextBlock Text="B" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" />
                                </Grid>
                            </Border>
                            <Border Margin="5" Background="#111">
                                <Grid>
                                    <Ellipse Stroke="#D7D7D7" StrokeThickness="8" Fill="#464646" Margin="14" />
                                    <Ellipse Stroke="#7A7A7A" StrokeThickness="4" Fill="#B0B0B0" Margin="36,30" />
                                    <Path Data="M130,146 L152,108 L164,148 Z" Fill="White" />
                                    <TextBlock Text="C" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" />
                                </Grid>
                            </Border>
                            <Border Margin="5" Background="#111">
                                <Grid>
                                    <Ellipse Stroke="#D7D7D7" StrokeThickness="8" Fill="#393939" Margin="14" />
                                    <Ellipse Stroke="#888" StrokeThickness="4" Fill="#969696" Margin="38,34" />
                                    <Path Data="M148,132 L188,118 L170,154 Z" Fill="White" />
                                    <TextBlock Text="D" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" />
                                </Grid>
                            </Border>
                            <Border Margin="5" Background="#111">
                                <Grid>
                                    <Ellipse Stroke="#CFCFCF" StrokeThickness="8" Fill="#3B3B3B" Margin="14,24" />
                                    <Ellipse Stroke="#777" StrokeThickness="4" Fill="#8A8A8A" Margin="45,50" />
                                    <Path Data="M110,128 L146,112 L132,150 Z" Fill="White" />
                                    <TextBlock Text="E" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" />
                                </Grid>
                            </Border>
                            <Border Margin="5" Background="#111">
                                <Grid>
                                    <Ellipse Stroke="#CFCFCF" StrokeThickness="8" Fill="#404040" Margin="14,24" />
                                    <Ellipse Stroke="#777" StrokeThickness="4" Fill="#929292" Margin="44,48" />
                                    <Path Data="M94,126 L130,110 L118,150 Z" Fill="White" />
                                    <TextBlock Text="F" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" />
                                </Grid>
                            </Border>
                            <Border Margin="5" Background="#111">
                                <Grid>
                                    <Ellipse Stroke="#D0D0D0" StrokeThickness="8" Fill="#444" Margin="14,24" />
                                    <Ellipse Stroke="#777" StrokeThickness="4" Fill="#999" Margin="44,48" />
                                    <Path Data="M112,116 L152,104 L136,144 Z" Fill="White" />
                                    <TextBlock Text="G" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" />
                                </Grid>
                            </Border>
                            <Border Margin="5" Background="#111">
                                <Grid>
                                    <Ellipse Stroke="#CFCFCF" StrokeThickness="8" Fill="#3B3B3B" Margin="14,24" />
                                    <Ellipse Stroke="#777" StrokeThickness="4" Fill="#8F8F8F" Margin="42,46" />
                                    <Path Data="M116,100 L154,82 L142,124 Z" Fill="White" />
                                    <TextBlock Text="H" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,2" />
                                </Grid>
                            </Border>
                        </UniformGrid>
                    </Border>
                </Viewbox>

                <DockPanel Grid.Row="2" Margin="18,0,18,14">
                    <TextBlock Text="{Binding Context.Localization.FemModelStatusText}"
                               Foreground="{StaticResource SubText}"
                               DockPanel.Dock="Left" />
                    <TextBlock Text="{Binding Context.Localization.FemSimulationStatusText}"
                               Foreground="{StaticResource SubText}"
                               HorizontalAlignment="Right" />
                </DockPanel>
            </Grid>
    </Grid>
</UserControl>


