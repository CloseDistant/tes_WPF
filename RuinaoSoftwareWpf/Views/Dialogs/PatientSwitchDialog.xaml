<Window x:Class="RuinaoSoftwareWpf.Views.Dialogs.PatientSwitchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="540"
        Height="390"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter Property="Background" Value="#2F3542" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#202634" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WorkbenchScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#4B5568" CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource Gold}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="#10151F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="2,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource WorkbenchScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Row"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#202736" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#30323B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Panel2}"
            BorderBrush="{StaticResource Line}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="16,0">
                    <Button Content="×"
                            DockPanel.Dock="Right"
                            Width="28"
                            Height="28"
                            Background="Transparent"
                            Foreground="{StaticResource SubText}"
                            BorderThickness="0"
                            FontSize="18"
                            Click="CancelButton_Click" />
                    <TextBlock Text="切换患者"
                               Foreground="{StaticResource Text}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="28,16,28,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="214" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox x:Name="SearchTextBox"
                         Height="30"
                         Margin="0,0,0,8"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         Background="#171C26"
                         Foreground="{StaticResource Text}"
                         CaretBrush="{StaticResource Text}"
                         BorderBrush="{StaticResource Line}"
                         BorderThickness="1"
                         ToolTip="按患者姓名或编号搜索"
                         TextChanged="SearchTextBox_TextChanged" />

                <Border Grid.Row="1" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ID" Foreground="{StaticResource SubText}" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock Grid.Column="1" Text="姓名" Foreground="{StaticResource SubText}" VerticalAlignment="Center" Margin="10,0" />
                        <TextBlock Grid.Column="2" Text="性别" Foreground="{StaticResource SubText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="年龄" Foreground="{StaticResource SubText}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Grid>
                </Border>

                <ListBox x:Name="PatientList"
                         Grid.Row="2"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding Items}"
                         ScrollViewer.ScrollChanged="PatientList_ScrollChanged"
                         MouseDoubleClick="PatientList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="28">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding PatientCode}" Foreground="{Binding TextBrush}" VerticalAlignment="Center" Margin="10,0" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                    <TextBlock Text="●" Foreground="{StaticResource Gold}" FontSize="9" Margin="0,0,8,0" Visibility="{Binding CurrentMarkerVisibility}" />
                                    <TextBlock Text="{Binding Name}" Foreground="{Binding TextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Sex}" Foreground="{Binding TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding Age}" Foreground="{Binding TextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock x:Name="ErrorText"
                           Grid.Row="3"
                           Foreground="{StaticResource Danger}"
                           Margin="0,8,0,0" />
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource Panel}"
                    BorderBrush="{StaticResource Line}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,4,4">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0">
                    <Button Content="取消"
                            Style="{StaticResource DialogButton}"
                            Margin="0,0,10,0"
                            Click="CancelButton_Click" />
                    <Button Content="确认"
                            Style="{StaticResource DialogButton}"
                            Click="OkButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
