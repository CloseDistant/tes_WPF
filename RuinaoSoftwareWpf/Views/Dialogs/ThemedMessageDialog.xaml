<Window x:Class="RuinaoSoftwareWpf.Views.Dialogs.ThemedMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        SizeToContent="Height"
        MinHeight="230"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="ConfirmButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="104" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="#D0903E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#D0903E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DCA04D" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#DCA04D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B8782E" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#B8782E" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#FFD07A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1C202B"
            BorderBrush="#3A4050"
            BorderThickness="1"
            CornerRadius="8"
            MouseLeftButtonDown="DialogRoot_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.45" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Background="#202532"
                    CornerRadius="8,8,0,0"
                    BorderBrush="#303645"
                    BorderThickness="0,0,0,1"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="IconBorder"
                            Width="32"
                            Height="32"
                            CornerRadius="16"
                            Background="#3A2E1D"
                            BorderBrush="#D0903E"
                            BorderThickness="1">
                        <TextBlock x:Name="IconText"
                                   Text="i"
                                   Foreground="#FFD07A"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   Foreground="#E4E8EF"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="CategoryText"
                                   Text="操作提示"
                                   Margin="0,4,0,0"
                                   Foreground="#8E96A8"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="1" Background="#171B25" Padding="22,24,22,22">
                <TextBlock x:Name="MessageText"
                           Foreground="#C8D0DE"
                           FontSize="14"
                           LineHeight="23"
                           TextWrapping="Wrap" />
            </Border>
            <Border Grid.Row="2"
                    Background="#1C202B"
                    CornerRadius="0,0,8,8"
                    BorderBrush="#303645"
                    BorderThickness="0,1,0,0"
                    Padding="18,14">
                <Button Content="确定"
                        Style="{StaticResource ConfirmButtonStyle}"
                        HorizontalAlignment="Right"
                        IsDefault="True"
                        IsCancel="True"
                        Click="ConfirmButton_Click" />
            </Border>
        </Grid>
    </Border>
</Window>
