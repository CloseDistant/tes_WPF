<Window x:Class="RuinaoSoftwareWpf.Views.Dialogs.AccountRegisterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RuinaoSoftwareWpf"
        Title="注册账号"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Border Background="#1C202B"
            BorderBrush="#3A4050"
            BorderThickness="1"
            CornerRadius="8"
            MouseLeftButtonDown="DialogRoot_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.45" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#202532"
                    CornerRadius="8,8,0,0"
                    BorderBrush="#303645"
                    BorderThickness="0,0,0,1"
                    Padding="20,15">
                <Grid>
                    <TextBlock Text="注册账号"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#E4E8EF" />
                    <Button Content="X"
                            HorizontalAlignment="Right"
                            Width="24"
                            Height="24"
                            Background="Transparent"
                            Foreground="#8E96A8"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"
                            Click="CancelButton_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,22,24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="96" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="42" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="登录名" VerticalAlignment="Center" Foreground="#C8D0DE" />
                <TextBox x:Name="LoginNameBox"
                         Grid.Column="1"
                         Height="30"
                         Background="#313644"
                         Foreground="#E4E8EF"
                         BorderBrush="#3B4150"
                         BorderThickness="1"
                         Padding="8,4"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="1" Text="密码" VerticalAlignment="Center" Foreground="#C8D0DE" />
                <PasswordBox x:Name="PasswordBox"
                             Grid.Row="1"
                             Grid.Column="1"
                             Height="30"
                             Background="#313644"
                             Foreground="#E4E8EF"
                             BorderBrush="#3B4150"
                             BorderThickness="1"
                             Padding="8,4"
                             VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="2" Text="再次输入密码" VerticalAlignment="Center" Foreground="#C8D0DE" />
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Grid.Row="2"
                             Grid.Column="1"
                             Height="30"
                             Background="#313644"
                             Foreground="#E4E8EF"
                             BorderBrush="#3B4150"
                             BorderThickness="1"
                             Padding="8,4"
                             VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="3" Text="姓名" VerticalAlignment="Center" Foreground="#C8D0DE" />
                <TextBox x:Name="DisplayNameBox"
                         Grid.Row="3"
                         Grid.Column="1"
                         Height="30"
                         Background="#313644"
                         Foreground="#E4E8EF"
                         BorderBrush="#3B4150"
                         BorderThickness="1"
                         Padding="8,4"
                         VerticalContentAlignment="Center" />

                <TextBlock Grid.Row="4" Text="职业" VerticalAlignment="Center" Foreground="#C8D0DE" />
                <Grid Grid.Row="4" Grid.Column="1" Height="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="DoctorRoleButton"
                            Content="Doctor"
                            Background="#D0903E"
                            Foreground="White"
                            BorderBrush="#D0903E"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="DoctorRoleButton_Click" />
                    <Button x:Name="TechnicianRoleButton"
                            Grid.Column="2"
                            Content="Technician"
                            Background="#313644"
                            Foreground="#C8D0DE"
                            BorderBrush="#3B4150"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="TechnicianRoleButton_Click" />
                </Grid>

                <TextBlock Grid.Row="5"
                           Grid.ColumnSpan="2"
                           Text="{x:Static local:AccountPasswordPolicy.RequirementText}"
                           Margin="0,8,0,0"
                           Foreground="#97A3B6"
                           FontSize="11"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="ErrorText"
                           Grid.Row="6"
                           Grid.ColumnSpan="2"
                           Margin="0,8,0,0"
                           Foreground="#E84E4F"
                           TextWrapping="Wrap" />
            </Grid>

            <Border Grid.Row="2"
                    Background="#1C202B"
                    CornerRadius="0,0,8,8"
                    BorderBrush="#303645"
                    BorderThickness="0,1,0,0"
                    Padding="18,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消"
                            MinWidth="86"
                            Height="34"
                            Margin="0,0,10,0"
                            Background="#272C38"
                            Foreground="#E4E8EF"
                            BorderBrush="#3A4050"
                            BorderThickness="1"
                            Cursor="Hand"
                            Click="CancelButton_Click" />
                    <Button Content="注册"
                            MinWidth="96"
                            Height="34"
                            Background="#1CA756"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="RegisterButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
