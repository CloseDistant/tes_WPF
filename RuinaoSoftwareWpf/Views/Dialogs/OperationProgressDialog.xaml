<Window x:Class="RuinaoSoftwareWpf.Views.Dialogs.OperationProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="260" WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False">
    <Border Background="#1B202B" BorderBrush="#4A5262" BorderThickness="1" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Background="#202633" BorderBrush="#343B49" BorderThickness="0,0,0,1" CornerRadius="5,5,0,0">
                <TextBlock x:Name="TitleText" Margin="20,0" VerticalAlignment="Center"
                           Foreground="#F0F3F8" FontSize="17" FontWeight="SemiBold" />
            </Border>
            <Grid Grid.Row="1" Margin="20,20,20,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="StageText" Foreground="#E7EBF2" FontSize="14" FontWeight="SemiBold" />
                <ProgressBar x:Name="OperationProgress" Grid.Row="1" Height="8" Margin="0,18,0,8"
                             Minimum="0" Maximum="100" Value="0" Foreground="#C88A32" Background="#0F141D" />
                <Grid Grid.Row="2">
                    <TextBlock x:Name="DetailText" Foreground="#96A1B3" FontSize="12" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="PercentText" HorizontalAlignment="Right" Foreground="#B7C0CF" FontSize="12" />
                </Grid>
                <Button x:Name="CancelButton" Grid.Row="3" Content="取消" Width="82" Height="34"
                        Margin="0,18,0,0" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Background="#252B37" Foreground="#CCD3DE" BorderBrush="#4B5668"
                        Click="CancelButton_Click" />
            </Grid>
        </Grid>
    </Border>
</Window>
