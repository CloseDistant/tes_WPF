<Window x:Class="RuinaoSoftwareWpf.Views.Dialogs.IntegrityCheckResultDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="620" SizeToContent="Height" MinHeight="390"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="ResultButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="116" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#9C681F" />
            <Setter Property="BorderBrush" Value="#B47A28" />
            <Setter Property="Foreground" Value="#F5E8D2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#B57927" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#845619" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1A202B" BorderBrush="#566174" BorderThickness="1" CornerRadius="3">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="0" Opacity="0.65" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="62" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="66" />
            </Grid.RowDefinitions>

            <Border Background="#1D2430" BorderBrush="#353E4C" BorderThickness="0,0,0,1" CornerRadius="3,3,0,0">
                <TextBlock x:Name="HeaderText" Text="校验完成" Margin="26,0"
                           VerticalAlignment="Center" Foreground="#F0F3F8"
                           FontSize="18" FontWeight="SemiBold" />
            </Border>

            <StackPanel Grid.Row="1" Margin="28,28,28,20">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="58" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ResultIconBorder" Width="58" Height="58" CornerRadius="29"
                            BorderThickness="3" BorderBrush="#38CB79">
                        <TextBlock x:Name="ResultIconText" Text="✓" Foreground="#4ADE89"
                                   FontFamily="Arial" FontSize="34"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="ResultTitleText" Foreground="#EEF2F7"
                                   FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock x:Name="ResultDetailText" Foreground="#A8B3C3"
                                   FontSize="12" Margin="0,7,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Border BorderBrush="#394352" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Grid x:Name="FirstResultRow" Height="54">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="210"/></Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="FirstLabelText" Foreground="#E0E5ED" FontSize="13" />
                                <TextBlock x:Name="FirstDescriptionText" Foreground="#8996A9" FontSize="11" Margin="0,3,0,0" />
                            </StackPanel>
                            <TextBlock x:Name="FirstValueText" Grid.Column="1" Foreground="#62D78C"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" />
                        </Grid>
                        <Border Height="1" Background="#394352" />
                        <Grid x:Name="SecondResultRow" Height="54">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="210"/></Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="SecondLabelText" Foreground="#E0E5ED" FontSize="13" />
                                <TextBlock x:Name="SecondDescriptionText" Foreground="#8996A9" FontSize="11" Margin="0,3,0,0" />
                            </StackPanel>
                            <TextBlock x:Name="SecondValueText" Grid.Column="1" Foreground="#62D78C"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" />
                        </Grid>
                        <Border Height="1" Background="#394352" />
                        <Grid Height="54">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="210"/></Grid.ColumnDefinitions>
                            <TextBlock Text="完成时间" Foreground="#E0E5ED" FontSize="13" VerticalAlignment="Center" />
                            <TextBlock x:Name="CompletedAtText" Grid.Column="1" Foreground="#62D78C"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13" />
                        </Grid>
                        <Border Height="1" Background="#394352" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" BorderBrush="#353E4C" BorderThickness="0,1,0,0" Padding="0,14,28,14">
                <Button Content="确定" Style="{StaticResource ResultButtonStyle}"
                        HorizontalAlignment="Right" IsDefault="True" Click="ConfirmButton_Click" />
            </Border>
        </Grid>
    </Border>
</Window>
