<Window x:Class="RuinaoSoftwareWpf.Views.Dialogs.BackupRequestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="590" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/><Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Foreground" Value="#E9EDF4"/>
            <Setter Property="Background" Value="#151A24"/><Setter Property="BorderBrush" Value="#4A5568"/>
        </Style>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/><Setter Property="Padding" Value="20,0"/>
            <Setter Property="Foreground" Value="#E6EBF3"/><Setter Property="Background" Value="#252B37"/>
            <Setter Property="BorderBrush" Value="#4A5568"/><Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Border Background="#1B202B" BorderBrush="#4A5262" BorderThickness="1" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="#202633" BorderBrush="#343B49" BorderThickness="0,0,0,1" CornerRadius="5,5,0,0">
                <TextBlock x:Name="TitleText" Margin="22,0" VerticalAlignment="Center" Foreground="#F0F3F8"
                           FontSize="18" FontWeight="SemiBold" />
            </Border>
            <StackPanel Grid.Row="1" Margin="22,20,22,20">
                <TextBlock x:Name="PathLabel" Text="保存位置" Foreground="#B8C1CF" Margin="0,0,0,8" />
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="50"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PathText" Style="{StaticResource InputStyle}" IsReadOnly="True" />
                    <Button Grid.Column="1" Width="40" Padding="0" Margin="10,0,0,0"
                            Style="{StaticResource ButtonStyle}" ToolTip="选择路径"
                            AutomationProperties.Name="选择路径" Click="BrowseButton_Click">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Button>
                </Grid>
                <TextBlock x:Name="LocationMessageText" Foreground="#D5A254" FontSize="12" Margin="0,8,0,0" />
                <Grid x:Name="SpaceGrid" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock x:Name="EstimateText" Foreground="#8F9BAD" FontSize="12" />
                    <TextBlock x:Name="AvailableText" Grid.Column="1" Foreground="#8F9BAD" FontSize="12" HorizontalAlignment="Right" />
                </Grid>
                <TextBlock Text="备份密码" Foreground="#B8C1CF" Margin="0,18,0,8" />
                <PasswordBox x:Name="PasswordInput" Height="38" Padding="10,0" VerticalContentAlignment="Center"
                             Foreground="#E9EDF4" Background="#151A24" BorderBrush="#4A5568" />
                <StackPanel x:Name="ConfirmPasswordPanel">
                    <TextBlock Text="确认密码" Foreground="#B8C1CF" Margin="0,14,0,8" />
                    <PasswordBox x:Name="ConfirmPasswordInput" Height="38" Padding="10,0" VerticalContentAlignment="Center"
                                 Foreground="#E9EDF4" Background="#151A24" BorderBrush="#4A5568" />
                </StackPanel>
                <TextBlock x:Name="ValidationText" Foreground="#FF747C" FontSize="12" MinHeight="18" Margin="0,8,0,0" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Content="取消" Style="{StaticResource ButtonStyle}" Width="112" Click="CancelButton_Click" />
                    <Button x:Name="ConfirmButton" Content="创建备份" Style="{StaticResource ButtonStyle}" Width="112"
                            Margin="10,0,0,0" Background="#B87D2F" BorderBrush="#B87D2F" Click="ConfirmButton_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
