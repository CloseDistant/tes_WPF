<Window x:Class="RuinaoSoftwareWpf.Views.Dialogs.PatientFormDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="620"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                                <Setter Property="Background" Value="#2F3542" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Gold}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="PatientFieldBox" TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
            <Setter Property="Height" Value="32" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="PatientErrorFieldBox" TargetType="TextBox" BasedOn="{StaticResource PatientFieldBox}">
            <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Background" Value="#3A3138" />
        </Style>
        <Style x:Key="CalendarNavButton" TargetType="Button">
            <Setter Property="Width" Value="28" /><Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" /><Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="CalendarDayButton" TargetType="Button">
            <Setter Property="Width" Value="32" /><Setter Property="Height" Value="28" /><Setter Property="Margin" Value="1" />
            <Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="BorderBrush" Value="Transparent" /><Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" /><Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Panel2}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1"
                    CornerRadius="4,4,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel Margin="18,0">
                    <Button Content="×" DockPanel.Dock="Right" Width="28" Height="28" Background="Transparent"
                            Foreground="{StaticResource SubText}" BorderThickness="0" FontSize="18" Click="CancelButton_Click" />
                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource Text}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="30,16,30,8">
                <Grid Height="40" Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="ID" Style="{StaticResource FieldLabel}" />
                    <TextBox Grid.Column="1" Text="{Binding PatientCode, Mode=OneWay}" Style="{StaticResource PatientFieldBox}" IsReadOnly="True" />
                </Grid>
                <Grid Height="40">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="姓名" /><Run Text="*" Foreground="{StaticResource Danger}" /></TextBlock>
                    <TextBox x:Name="NameBox" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="20" Style="{StaticResource PatientFieldBox}" />
                </Grid>
                <Grid Height="40">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="性别" /><Run Text="*" Foreground="{StaticResource Danger}" /></TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton Content="男性" IsChecked="{Binding IsMale}" Foreground="{StaticResource Text}" Margin="0,0,24,0" />
                        <RadioButton Content="女性" IsChecked="{Binding IsFemale}" Foreground="{StaticResource Text}" />
                    </StackPanel>
                </Grid>
                <Grid Height="40">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource FieldLabel}"><Run Text="出生日期" /><Run Text="*" Foreground="{StaticResource Danger}" /></TextBlock>
                    <TextBox x:Name="BirthDateBox" Grid.Column="1" Text="{Binding BirthDateText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PatientFieldBox}" IsReadOnly="True" Cursor="Hand"
                             PreviewMouseLeftButtonDown="BirthDateBox_PreviewMouseLeftButtonDown" GotKeyboardFocus="BirthDateBox_GotKeyboardFocus" />
                </Grid>
                <StackPanel Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Height="40">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="身份证号" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1" Text="{Binding IdCardNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PatientFieldBox}" />
                    </Grid>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource FieldLabel}"><Run Text="联系电话" /><Run Text="*" Foreground="{StaticResource Danger}" /></TextBlock>
                        <TextBox x:Name="PhoneBox" Grid.Column="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewTextInput="PhoneBox_PreviewTextInput" DataObject.Pasting="PhoneBox_Pasting"
                                 Style="{StaticResource PatientFieldBox}" />
                    </Grid>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="紧急联系人" Style="{StaticResource FieldLabel}" />
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Grid>
                                <TextBox x:Name="EmergencyNameBox" Text="{Binding EmergencyContactName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PatientFieldBox}" GotKeyboardFocus="EmergencyPlaceholder_FocusChanged" LostKeyboardFocus="EmergencyPlaceholder_FocusChanged" />
                                <TextBlock x:Name="EmergencyNamePlaceholder" Text="姓名" Foreground="#AEB4C1" Opacity="0.62" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" />
                            </Grid>
                            <Grid Grid.Column="2">
                                <TextBox x:Name="EmergencyPhoneBox" Text="{Binding EmergencyContactPhone, UpdateSourceTrigger=PropertyChanged}"
                                         PreviewTextInput="PhoneBox_PreviewTextInput" DataObject.Pasting="PhoneBox_Pasting"
                                         Style="{StaticResource PatientFieldBox}" GotKeyboardFocus="EmergencyPlaceholder_FocusChanged" LostKeyboardFocus="EmergencyPlaceholder_FocusChanged" />
                                <TextBlock x:Name="EmergencyPhonePlaceholder" Text="电话" Foreground="#AEB4C1" Opacity="0.62" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" />
                            </Grid>
                        </Grid>
                    </Grid>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="家庭住址" Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Column="1" Text="{Binding HomeAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PatientFieldBox}" />
                    </Grid>
                </StackPanel>
                <Grid Height="132" Visibility="{Binding IsCreateMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="105" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <TextBlock Text="临床信息" Style="{StaticResource FieldLabel}" VerticalAlignment="Top" Margin="0,8,0,0" />
                    <TextBox Grid.Column="1" Height="116" Text="{Binding ClinicalInfo, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PatientFieldBox}" AcceptsReturn="True" TextWrapping="Wrap" Padding="10,8" VerticalContentAlignment="Top" />
                </Grid>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}" Margin="105,6,0,0" />
            </StackPanel>

            <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" CornerRadius="0,0,4,4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0">
                    <Button Content="取消" Style="{StaticResource DialogButton}" Margin="0,0,10,0" Click="CancelButton_Click" />
                    <Button Content="确认" Style="{StaticResource DialogButton}" Click="OkButton_Click" />
                </StackPanel>
            </Border>

            <Popup x:Name="DatePickerPopup" Placement="Bottom" StaysOpen="True" AllowsTransparency="True">
                <Border Width="256" Background="#202532" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="4" Padding="10">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <Button Content="‹" DockPanel.Dock="Left" Style="{StaticResource CalendarNavButton}" Click="PreviousMonthButton_Click" />
                            <Button Content="›" DockPanel.Dock="Right" Style="{StaticResource CalendarNavButton}" Click="NextMonthButton_Click" />
                            <TextBlock x:Name="CalendarTitleText" Foreground="{StaticResource Text}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </DockPanel>
                        <UniformGrid Columns="7" Margin="0,0,0,4">
                            <TextBlock Text="一" Foreground="{StaticResource SubText}" TextAlignment="Center" /><TextBlock Text="二" Foreground="{StaticResource SubText}" TextAlignment="Center" />
                            <TextBlock Text="三" Foreground="{StaticResource SubText}" TextAlignment="Center" /><TextBlock Text="四" Foreground="{StaticResource SubText}" TextAlignment="Center" />
                            <TextBlock Text="五" Foreground="{StaticResource SubText}" TextAlignment="Center" /><TextBlock Text="六" Foreground="{StaticResource SubText}" TextAlignment="Center" />
                            <TextBlock Text="日" Foreground="{StaticResource SubText}" TextAlignment="Center" />
                        </UniformGrid>
                        <UniformGrid x:Name="CalendarDaysGrid" Columns="7" Rows="6" />
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>
