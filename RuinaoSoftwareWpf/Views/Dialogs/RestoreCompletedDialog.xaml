<Window x:Class="RuinaoSoftwareWpf.Views.Dialogs.RestoreCompletedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" SizeToContent="Height" WindowStartupLocation="CenterOwner" WindowStyle="None"
        ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False">
    <Border Background="#1B202B" BorderBrush="#4A5262" BorderThickness="1" CornerRadius="5">
        <StackPanel>
            <Border Background="#202633" BorderBrush="#343B49" BorderThickness="0,0,0,1" Padding="20,17" CornerRadius="5,5,0,0">
                <TextBlock x:Name="RestoreTitleText" Text="数据恢复完成" Foreground="#F0F3F8" FontSize="18" FontWeight="SemiBold" />
            </Border>
            <TextBlock x:Name="RestoreMessageText" Text="数据已成功恢复。请退出软件后重新打开，使恢复后的数据生效。"
                       Margin="22,24,22,20" Foreground="#CFD6E1" FontSize="14" TextWrapping="Wrap" />
            <Border BorderBrush="#343B49" BorderThickness="0,1,0,0" Padding="18,14">
                <Button Content="退出软件" Width="112" Height="36" HorizontalAlignment="Right"
                        Background="#7B5C32" BorderBrush="#92703F" Foreground="#F0E6D7" Click="ExitButton_Click" />
            </Border>
        </StackPanel>
    </Border>
</Window>
