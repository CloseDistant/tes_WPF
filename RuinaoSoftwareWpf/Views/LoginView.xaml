<UserControl x:Class="RuinaoSoftwareWpf.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#11141D">
    <UserControl.Resources>
        <Style x:Key="LoginTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="46" />
            <Setter Property="Background" Value="#171B25" />
            <Setter Property="Foreground" Value="#E4E8EF" />
            <Setter Property="BorderBrush" Value="#3B4150" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,8" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#D0903E" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="LoginPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="46" />
            <Setter Property="Background" Value="#171B25" />
            <Setter Property="Foreground" Value="#E4E8EF" />
            <Setter Property="BorderBrush" Value="#3B4150" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="13,8,44,8" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#D0903E" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RememberCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#C8D0DE" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="CheckBorder"
                                    Width="18"
                                    Height="18"
                                    Background="#171B25"
                                    BorderBrush="#4A5161"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckGlyph"
                                      Data="M2,6 L5,9 L11,2"
                                      Stroke="#171B25"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"
                                      Margin="2" />
                            </Border>
                            <ContentPresenter Margin="9,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#D0903E" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#D0903E" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#DCA04D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="Background" Value="#1CA756" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#24B963" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#178C48" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LoginMoreButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E4E8EF" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#343640" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#343640" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#464A56" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LoginMenuItem" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#E4E8EF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#343944" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="22" />
        </Grid.RowDefinitions>

        <Border Background="#2A2B31" BorderBrush="#333640" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="☼"
                               Foreground="#D6A04C"
                               FontSize="15"
                               VerticalAlignment="Center"
                               Margin="0,0,3,0" />
                    <TextBlock Text="经颅直流电刺激上位机软件"
                               Foreground="#F1F2F5"
                               FontSize="14"
                               VerticalAlignment="Center" />
                </StackPanel>

                <ToggleButton x:Name="LoginMoreToggle"
                              Content="..."
                              Style="{StaticResource LoginMoreButton}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,10,0" />
                <Popup IsOpen="{Binding IsChecked, ElementName=LoginMoreToggle}"
                       PlacementTarget="{Binding ElementName=LoginMoreToggle}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Width="142"
                            Background="#1C202B"
                            BorderBrush="#303645"
                            BorderThickness="1"
                            Padding="0,4">
                        <Button Content="退出软件"
                                Style="{StaticResource LoginMenuItem}"
                                Click="ExitButton_Click" />
                    </Border>
                </Popup>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Background="#11141D">
            <Border Width="520"
                    Background="#1C202B"
                    BorderBrush="#3A4050"
                    BorderThickness="1"
                    CornerRadius="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="28,26,28,28">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Width="3" Height="26" Background="#D0903E" Margin="0,0,12,0" />
                        <TextBlock Text="账号登录"
                                   Foreground="#E4E8EF"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Height="1" Background="#303645" Margin="0,-10,0,20" />

                    <TextBlock Text="登录名" Foreground="#C8D0DE" FontSize="14" Margin="0,0,0,7" />
                    <TextBox x:Name="LoginNameBox" Style="{StaticResource LoginTextBox}" />

                    <TextBlock Text="密码" Foreground="#C8D0DE" FontSize="14" Margin="0,20,0,7" />
                    <Grid>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource LoginPasswordBox}" />
                        <TextBox x:Name="VisiblePasswordBox"
                                 Style="{StaticResource LoginTextBox}"
                                 Padding="13,8,44,8"
                                 Visibility="Collapsed" />
                        <ToggleButton x:Name="PasswordRevealButton"
                                      Width="38"
                                      Height="38"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0"
                                      Background="Transparent"
                                      Foreground="#8E96A8"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      ToolTip="显示或隐藏密码"
                                      Checked="PasswordRevealButton_Checked"
                                      Unchecked="PasswordRevealButton_Unchecked">
                            <Path Data="M12,4.5 C7,4.5 2.73,7.61 1,12 C2.73,16.39 7,19.5 12,19.5 C17,19.5 21.27,16.39 23,12 C21.27,7.61 17,4.5 12,4.5 M12,17 C9.24,17 7,14.76 7,12 C7,9.24 9.24,7 12,7 C14.76,7 17,9.24 17,12 C17,14.76 14.76,17 12,17 M12,9 C10.34,9 9,10.34 9,12 C9,13.66 10.34,15 12,15 C13.66,15 15,13.66 15,12 C15,10.34 13.66,9 12,9"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                  Width="18"
                                  Height="18"
                                  Stretch="Uniform" />
                        </ToggleButton>
                    </Grid>

                    <CheckBox x:Name="RememberAccountCheckBox"
                              Content="记住账号"
                              IsChecked="True"
                              Style="{StaticResource RememberCheckBox}"
                              Margin="0,18,0,0" />

                    <TextBlock x:Name="MessageText"
                               MinHeight="20"
                               Margin="0,12,0,7"
                               Foreground="#E84E4F"
                               FontSize="13"
                               TextWrapping="Wrap" />

                    <Button x:Name="LoginButtonControl"
                            Content="登录"
                            Style="{StaticResource LoginButton}"
                            IsDefault="True"
                            Click="LoginButton_Click" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#11141D" BorderBrush="#303645" BorderThickness="0,1,0,0">
            <TextBlock x:Name="ClockText"
                       Foreground="#8E96A8"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,14,0" />
        </Border>
    </Grid>
</UserControl>
