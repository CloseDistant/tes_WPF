<UserControl x:Class="RuinaoSoftwareWpf.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="ConfigView_Loaded"
             Unloaded="ConfigView_Unloaded">
    <UserControl.Resources>
        <Style x:Key="ConfigScrollBarThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="#4B5568"
                                CornerRadius="3" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#D0903E" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#E2A85A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="#10151F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Margin="2,0">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ConfigScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource ConfigScrollBar}" />

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C8CEDA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FeatureCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E1E6EE" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <ContentPresenter Margin="0,0,34,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch" />
                            <Border x:Name="CheckBorder"
                                    Width="18"
                                    Height="18"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="#252A36"
                                    BorderBrush="#596274"
                                    BorderThickness="1"
                                    CornerRadius="2">
                                <Path x:Name="CheckGlyph"
                                      Data="M2,6 L5,9 L11,2"
                                      Stroke="#171B24"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Visibility="Collapsed"
                                      Margin="2" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#D0903E" />
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#D0903E" />
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#E1A34D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsActionButton" TargetType="Button">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="#D8DEE8" />
            <Setter Property="Background" Value="#272C38" />
            <Setter Property="BorderBrush" Value="#465064" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonSurface" Property="BorderBrush" Value="#6B778C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonSurface" Property="Background" Value="#242832" />
                                <Setter TargetName="ButtonSurface" Property="BorderBrush" Value="#373E4B" />
                                <Setter Property="Foreground" Value="#667181" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecurityStepButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#252A36" />
            <Setter Property="Foreground" Value="#E1E6EE" />
            <Setter Property="BorderBrush" Value="#596274" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="StepSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="0,-2,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StepSurface" Property="Background" Value="#303746" />
                                <Setter TargetName="StepSurface" Property="BorderBrush" Value="#78859A" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="StepSurface" Property="Background" Value="#1D222C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <!-- 禁用态沿用深色主题，只降低层级和对比度，不使用系统默认白色。 -->
                                <Setter TargetName="StepSurface" Property="Background" Value="#222630" />
                                <Setter TargetName="StepSurface" Property="BorderBrush" Value="#373E4B" />
                                <Setter Property="Foreground" Value="#596474" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FeatureOptionTemplate">
            <Border Height="41"
                    Margin="0,0,0,9"
                    Padding="14,0"
                    Background="#343A49"
                    BorderBrush="#414859"
                    BorderThickness="1">
                <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay}"
                          Style="{StaticResource FeatureCheckBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding OrderText}"
                                   Foreground="#7F8CA4"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DisplayName}"
                                   Foreground="#E1E6EE"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ShortName}"
                                   Foreground="#8D99AD"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </Grid>
                </CheckBox>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.9*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" Background="#303139" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,28">
                <TextBlock Text="数据备份与恢复" Foreground="{StaticResource Text}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16" />
                <Grid Height="32">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="104"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="最近备份" Style="{StaticResource SettingLabel}" />
                    <TextBlock x:Name="LastBackupAtText" Grid.Column="1" Text="尚未备份" Style="{StaticResource SettingValue}" />
                </Grid>
                <Grid Height="32">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="104"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="备份文件" Style="{StaticResource SettingLabel}" />
                    <TextBlock x:Name="LastBackupFileText" Grid.Column="1" Text="--" Style="{StaticResource SettingValue}" TextTrimming="CharacterEllipsis" />
                </Grid>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Button Content="恢复数据" Style="{StaticResource SettingsActionButton}" IsEnabled="{Binding IsAdmin}" Click="RestoreDataButton_Click" Margin="0,0,6,0" />
                    <Button Grid.Column="1" Content="创建备份" Style="{StaticResource SettingsActionButton}" IsEnabled="{Binding IsAdmin}"
                            Click="CreateBackupButton_Click" Margin="6,0,0,0" Background="#B87D2F" BorderBrush="#B87D2F" Foreground="White" />
                </Grid>

                <Border Height="1" Background="#444650" Margin="0,22,0,20" />
                <TextBlock Text="发布文件完整性" Foreground="{StaticResource Text}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,14" />
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="32"/><RowDefinition Height="40"/></Grid.RowDefinitions>
                    <TextBlock x:Name="ReleaseIntegrityStatusText" Text="尚未校验" Style="{StaticResource SettingValue}" VerticalAlignment="Center" />
                    <TextBlock x:Name="ReleaseIntegrityTimeText" Grid.Row="1" Text="--" Style="{StaticResource SettingLabel}" VerticalAlignment="Center" />
                    <Button Grid.Row="1" Content="开始校验" Style="{StaticResource SettingsActionButton}" HorizontalAlignment="Right"
                            IsEnabled="{Binding IsAdmin}" Click="ReleaseIntegrityButton_Click" />
                </Grid>

                <Border Height="1" Background="#444650" Margin="0,22,0,20" />
                <TextBlock Text="软件信息" Foreground="{StaticResource Text}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,18" />
                <Grid Height="36">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="软件版本" Style="{StaticResource SettingLabel}" />
                    <TextBlock Grid.Column="1" Text="V1.0.0" Style="{StaticResource SettingValue}" />
                </Grid>
                <Grid Height="36">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="硬件版本" Style="{StaticResource SettingLabel}" />
                    <TextBlock Grid.Column="1" Text="V1.0.1" Style="{StaticResource SettingValue}" />
                </Grid>
                <Grid Height="36">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="发布日期" Style="{StaticResource SettingLabel}" />
                    <TextBlock Grid.Column="1" Text="2026-06-10" Style="{StaticResource SettingValue}" />
                </Grid>
                <Grid Height="36">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="SN" Style="{StaticResource SettingLabel}" />
                    <TextBlock Grid.Column="1" Text="12345678" Style="{StaticResource SettingValue}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Column="1"
                      Background="#303139"
                      BorderBrush="#3A3C45"
                      BorderThickness="1,0,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,20,24,28">
                <TextBlock Text="安全设置"
                           Foreground="{StaticResource Text}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,16" />

                <Border Background="#2A2D36"
                        BorderBrush="#414859"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="18,16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="自动锁定"
                                       Foreground="#E1E6EE"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Ellipse Width="7" Height="7" Fill="#56D981" Margin="0,0,7,0" />
                                <TextBlock Text="已启用" Foreground="#78D995" FontSize="12" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="达到设定的无操作时间后，软件将锁定当前会话。"
                                   Foreground="#929DAF"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20" />

                        <TextBlock Text="无操作锁定时间"
                                   Foreground="#C8CEDA"
                                   FontSize="13"
                                   Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="−"
                                    Command="{Binding DecreaseIdleTimeoutCommand}"
                                    Style="{StaticResource SecurityStepButton}"
                                    IsEnabled="{Binding IsAdmin}" />
                            <Border Width="100"
                                    Height="36"
                                    Background="#202632"
                                    BorderBrush="#667187"
                                    BorderThickness="1"
                                    Margin="10,0">
                                <TextBlock Text="{Binding IdleTimeoutMinutes}"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <Button Content="+"
                                    Command="{Binding IncreaseIdleTimeoutCommand}"
                                    Style="{StaticResource SecurityStepButton}"
                                    IsEnabled="{Binding IsAdmin}" />
                            <TextBlock Text="分钟"
                                       Foreground="#AEB8C9"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0" />
                        </StackPanel>
                        <Slider Minimum="5"
                                Maximum="30"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding IdleTimeoutMinutes, Mode=TwoWay}"
                                IsEnabled="{Binding IsAdmin}"
                                Foreground="#D0903E"
                                Margin="0,0,0,2" />
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="5" Foreground="#7F8CA4" FontSize="10" />
                            <TextBlock Grid.Column="1" Text="10" Foreground="#7F8CA4" FontSize="10" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="15" Foreground="#7F8CA4" FontSize="10" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="20" Foreground="#7F8CA4" FontSize="10" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="25" Foreground="#7F8CA4" FontSize="10" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="30" Foreground="#7F8CA4" FontSize="10" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding SessionSecurityStatus}"
                               Foreground="#5DDA77"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,18,0" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="恢复默认"
                                Command="{Binding RestoreSessionSecurityCommand}"
                                Style="{StaticResource SettingsActionButton}"
                                IsEnabled="{Binding IsAdmin}" />
                        <Button Content="保存设置"
                                Command="{Binding SaveSessionSecurityCommand}"
                                Style="{StaticResource SettingsActionButton}"
                                IsEnabled="{Binding IsAdmin}"
                                Background="#1CA756"
                                BorderBrush="#1CA756"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Margin="10,0,0,0" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer Grid.Column="2"
                      Visibility="{Binding NavigationSettingsVisibility}"
                      Background="#303139"
                      BorderBrush="#3A3C45"
                      BorderThickness="1,0,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="高级设置"
                           Foreground="{StaticResource Text}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="24,20,24,0" />
                <StackPanel Margin="24,20,24,20">
                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="导航栏显示管理"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <CheckBox Content="全部显示"
                                  IsChecked="{Binding AllNavigationVisible, Mode=TwoWay}"
                                  Style="{StaticResource FeatureCheckBox}"
                                  Width="88"
                                  HorizontalAlignment="Right" />
                    </Grid>
                    <TextBlock Text="选择需要显示在左侧导航栏中的业务页面"
                               Foreground="#AAB4C5"
                               FontSize="12"
                               Margin="0,0,0,14" />
                    <ItemsControl ItemsSource="{Binding NavigationOptions}"
                                  ItemTemplate="{StaticResource FeatureOptionTemplate}" />
                    <TextBlock Text="“设置”固定显示，不参与屏蔽"
                               Foreground="#929DAF"
                               FontSize="11"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding NavigationStatus}"
                               Foreground="#5DDA77"
                               FontSize="11"
                               MinHeight="18"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,8,0,0">
                        <Button Content="恢复默认"
                                Command="{Binding RestoreNavigationCommand}"
                                Style="{StaticResource SettingsActionButton}" />
                        <Button Content="保存设置"
                                Command="{Binding SaveNavigationCommand}"
                                Style="{StaticResource SettingsActionButton}"
                                Background="#1CA756"
                                BorderBrush="#1CA756"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Margin="10,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Height="1"
                        Background="#3A3C45"
                        Visibility="{Binding StimulationSettingsVisibility}" />

                <StackPanel Margin="24,24,24,20"
                            Visibility="{Binding StimulationSettingsVisibility}">
                    <Grid Margin="0,0,0,24">
                        <TextBlock Text="电刺激类型显示管理"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <CheckBox Content="全部显示"
                                  IsChecked="{Binding AllStimulationTypesVisible, Mode=TwoWay}"
                                  Style="{StaticResource FeatureCheckBox}"
                                  Width="88"
                                  HorizontalAlignment="Right" />
                    </Grid>
                    <TextBlock Text="选择电刺激模式选择页中需要显示的刺激类型"
                               Foreground="#AAB4C5"
                               FontSize="12"
                               Margin="0,0,0,14" />
                    <ItemsControl ItemsSource="{Binding StimulationTypeOptions}"
                                  ItemTemplate="{StaticResource FeatureOptionTemplate}" />
                    <TextBlock Text="至少保留一种刺激类型用于模式选择"
                               Foreground="#929DAF"
                               FontSize="11"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding StimulationStatus}"
                               Foreground="#5DDA77"
                               FontSize="11"
                               MinHeight="18"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,8,0,0">
                        <Button Content="恢复默认"
                                Command="{Binding RestoreStimulationTypesCommand}"
                                Style="{StaticResource SettingsActionButton}" />
                        <Button Content="保存设置"
                                Command="{Binding SaveStimulationTypesCommand}"
                                Style="{StaticResource SettingsActionButton}"
                                Background="#1CA756"
                                BorderBrush="#1CA756"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Margin="10,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Height="1" Background="#3A3C45" />

                <StackPanel Margin="24,24,24,24">
                    <TextBlock Text="桌面快捷方式"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <TextBlock Text="创建或更新桌面快捷方式，使其指向当前运行的软件版本"
                               Foreground="#AAB4C5"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,18" />
                    <Button Content="创建桌面快捷方式"
                            Command="{Binding CreateDesktopShortcutCommand}"
                            Style="{StaticResource SettingsActionButton}"
                            Width="160"
                            HorizontalAlignment="Left" />
                </StackPanel>

                <Border Height="1" Background="#3A3C45" />

                <StackPanel Margin="24,24,24,28">
                    <TextBlock Text="启动设置"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />
                    <TextBlock Text="设置软件启动后的设备联机行为"
                               Foreground="#AAB4C5"
                               FontSize="12"
                               Margin="0,0,0,14" />
                    <Border Height="50"
                            Padding="14,0"
                            Background="#343A49"
                            BorderBrush="#414859"
                            BorderThickness="1">
                        <CheckBox Content="软件启动时自动联机"
                                  IsChecked="{Binding AutoConnectOnStartup, Mode=TwoWay}"
                                  IsEnabled="{Binding IsAdmin}"
                                  Style="{StaticResource FeatureCheckBox}" />
                    </Border>
                    <TextBlock Text="开启后，软件启动并完成初始化后将自动尝试联机"
                               Foreground="#929DAF"
                               FontSize="11"
                               Margin="0,10,0,0" />
                    <TextBlock Text="{Binding StartupSettingsStatus}"
                               Foreground="#5DDA77"
                               FontSize="11"
                               MinHeight="18"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,8,0,0">
                        <Button Content="恢复默认"
                                Command="{Binding RestoreStartupSettingsCommand}"
                                Style="{StaticResource SettingsActionButton}" />
                        <Button Content="保存设置"
                                Command="{Binding SaveStartupSettingsCommand}"
                                Style="{StaticResource SettingsActionButton}"
                                Background="#1CA756"
                                BorderBrush="#1CA756"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Margin="10,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
