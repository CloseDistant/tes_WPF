<UserControl x:Class="RuinaoSoftwareWpf.Views.Controls.AssessmentWorkflowSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Padding="14">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="{Binding ProcessTitleText}" Style="{DynamicResource SectionTitle}" />
                <TextBlock Text="{Binding CurrentStepText}" Foreground="{StaticResource Gold}" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,0" />
            </StackPanel>

            <StackPanel Visibility="{Binding IsCaptureTaskModule, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Margin="0,5,0,13">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Style="{DynamicResource StepDot}" Background="{Binding DemoStepBrushValue}" />
                    <TextBlock Grid.Column="1" Text="{Binding DemoStepTitleText}" Foreground="{Binding DemoStepTextBrush}" FontWeight="SemiBold" />
                </Grid>
                <Grid Margin="0,0,0,13">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Style="{DynamicResource StepDot}" Background="{Binding FaceStepBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding FaceStepTitleText}" Foreground="{Binding FaceStepTextBrush}" FontWeight="SemiBold" />
                </Grid>
                <Grid Margin="0,0,0,13">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Style="{DynamicResource StepDot}" Background="{Binding CalibrationStepBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding CurrentModule, StringFormat=3. {0}}" Foreground="{Binding CalibrationStepTextBrush}" FontWeight="SemiBold" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Style="{DynamicResource StepDot}" Background="{Binding ImageBrowseStepBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding CompletedStepTitleText}" Foreground="{Binding ImageBrowseStepTextBrush}" FontWeight="SemiBold" />
                </Grid>
            </StackPanel>

            <StackPanel Visibility="{Binding IsFormModule, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Margin="0,5,0,13">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Style="{DynamicResource StepDot}" Background="{Binding FormFillStepBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding FormFillStepTitleText}" Foreground="{Binding FormFillStepTextBrush}" FontWeight="SemiBold" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Style="{DynamicResource StepDot}" Background="{Binding FormCompletedStepBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding FormCompletedStepTitleText}" Foreground="{Binding FormCompletedStepTextBrush}" FontWeight="SemiBold" />
                </Grid>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
