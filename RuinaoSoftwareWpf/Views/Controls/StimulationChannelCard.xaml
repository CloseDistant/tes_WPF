<UserControl x:Class="RuinaoSoftwareWpf.Views.Controls.StimulationChannelCard"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:renderers="clr-namespace:RuinaoSoftwareWpf.Views.Renderers"
             Background="Transparent"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="WaveformModeOption" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#8593AA" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="OptionSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="12,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OptionSurface" Property="Background" Value="#252F3F" />
                                <Setter Property="Foreground" Value="#D7DFEA" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OptionSurface" Property="Background" Value="#313A49" />
                                <Setter Property="Foreground" Value="#F1B24A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource SelectedCard}" Padding="20" MinHeight="640" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding Localization.StartButtonText, ElementName=Root}"
                            Command="{Binding StartCommand, ElementName=Root}"
                            CommandParameter="{Binding}"
                            Style="{StaticResource TopButton}"
                            Background="#27B65A"
                            Height="32"
                            MinWidth="70"
                            Padding="14,5"
                            Margin="0,0,12,0" />
                    <TextBlock Text="{Binding Localization.RemainingTimeLabel, ElementName=Root}"
                               Foreground="{StaticResource SubText}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <Border Background="#303644" CornerRadius="5" Padding="14,6">
                        <TextBlock Text="{Binding RemainingTime}"
                                   FontFamily="Consolas"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{Binding AccentBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>

            <StackPanel Grid.Row="1" Margin="0,22,0,14">
                <TextBlock Text="{Binding Localization.StatusMonitorLabel, ElementName=Root}"
                           Foreground="{StaticResource SubText}" />
                <Border Background="#171B25" Margin="0,10,0,0" Padding="18,14" MinHeight="112">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ImpedanceOhm}"
                                   FontSize="46"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Yellow}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Localization.ImpedanceLabel, ElementName=Root}"
                                   Foreground="{StaticResource SubText}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,4,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.AmplitudeLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource StimulationFieldBox}" Text="{Binding CurrentMA, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsParameterEditingEnabled}" />
                        <TextBlock Grid.Column="2" Text="mA" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                    </Grid>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.RampUpLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource StimulationFieldBox}" Text="{Binding RampUpS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsParameterEditingEnabled}" />
                        <TextBlock Grid.Column="2" Text="s" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                    </Grid>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.RampDownLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource StimulationFieldBox}" Text="{Binding RampDownS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsParameterEditingEnabled}" />
                        <TextBlock Grid.Column="2" Text="s" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                    </Grid>
                    <Grid Height="40"
                          Visibility="{Binding ShowPolarity, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.PolarityLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource StimulationComboBox}"
                                  IsEnabled="{Binding IsParameterEditingEnabled}"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding Polarity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Content="不掉转" />
                            <ComboBoxItem Content="调转" />
                        </ComboBox>
                    </Grid>
                    <Grid Height="40" Visibility="{Binding ShowCarrierFrequency, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.CarrierFrequencyLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource StimulationFieldBox}" Text="{Binding FrequencyHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsParameterEditingEnabled}" />
                        <TextBlock Grid.Column="2" Text="Hz" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                    </Grid>
                </StackPanel>

                <Border Grid.Column="1" Background="#303645" />

                <StackPanel Grid.Column="2" Margin="18,0,0,0">
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.ModeLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource StimulationComboBox}"
                                  IsEnabled="{Binding IsParameterEditingEnabled}"
                                  SelectedValuePath="Content"
                                  SelectedValue="{Binding StimulationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <ComboBoxItem Content="间隔" />
                            <ComboBoxItem Content="连续" />
                        </ComboBox>
                    </Grid>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.DurationLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Style="{StaticResource StimulationFieldBox}" Text="{Binding DurationS, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsParameterEditingEnabled}" />
                        <TextBlock Grid.Column="2" Text="s" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource SubText}" />
                    </Grid>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.IntervalTimeLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource StimulationFieldBox}"
                                 Text="{Binding IntervalDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding AreIntervalFieldsEditable}" />
                        <TextBlock Grid.Column="2"
                                   Text="s"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubText}"
                                   Visibility="{Binding AreIntervalFieldsEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                    <Grid Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="66" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="36" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Localization.SingleDurationLabel, ElementName=Root}" Foreground="{StaticResource SubText}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource StimulationFieldBox}"
                                 Text="{Binding SingleDurationDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding AreIntervalFieldsEditable}" />
                        <TextBlock Grid.Column="2"
                                   Text="s"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubText}"
                                   Visibility="{Binding AreIntervalFieldsEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Border Grid.Row="3"
                    Background="#121823"
                    Padding="16"
                    BorderBrush="#293243"
                    BorderThickness="1"
                    CornerRadius="4"
                    MinHeight="190"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Right"
                                Background="#1A2230"
                                BorderBrush="#303B4D"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="2"
                                Visibility="{Binding EnableSimulatedWaveform, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="120 秒"
                                             GroupName="{Binding Name}"
                                             Style="{StaticResource WaveformModeOption}"
                                             IsChecked="{Binding DirectCurrentWaveform.IsWindowView, Mode=TwoWay}" />
                                <RadioButton Content="全程"
                                             GroupName="{Binding Name}"
                                             Style="{StaticResource WaveformModeOption}"
                                             IsChecked="{Binding DirectCurrentWaveform.IsGlobalView, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Localization.WaveformLabel, ElementName=Root}"
                                       Foreground="#CBD5E4"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </DockPanel>
                    <Border Grid.Row="1"
                            Margin="0,10,0,0"
                            Background="#0E1520"
                            BorderBrush="#263142"
                            BorderThickness="1"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <renderers:DirectCurrentWaveformSurface State="{Binding DirectCurrentWaveform}"
                                                                    Visibility="{Binding EnableSimulatedWaveform, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Border>
                </Grid>
            </Border>

            <TextBlock Grid.Row="4"
                       Margin="0,14,0,0"
                       Foreground="{StaticResource SubText}"
                       Visibility="{Binding ShowElectrodeDescription, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
                <Run Text="{Binding Localization.ElectrodeLabel, ElementName=Root, Mode=OneWay}" />
                <Run Text="{Binding Anode}" />
                <Run Text=" / " />
                <Run Text="{Binding Cathode}" />
            </TextBlock>
        </Grid>
    </Border>
</UserControl>
