<UserControl x:Class="RuinaoSoftwareWpf.Views.PlaceholderPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#11141D">
    <Grid Margin="24">
        <Border Background="#1C202B"
                BorderBrush="#303645"
                BorderThickness="1"
                CornerRadius="6"
                Padding="24"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Foreground="#D0903E"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Description}"
                           Foreground="#8E96A8"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Margin="0,14,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
